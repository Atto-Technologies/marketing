---
/**
 * DefineTerm — inline word with a dictionary-style definition popover.
 *
 * Visual: the term is rendered with a dotted underline (the long-standing
 * <abbr>/<dfn> convention for a defined term). Mouse hover, keyboard focus,
 * and click/tap each reveal a small definition card positioned just below
 * the word.
 *
 * Accessibility:
 *   - The trigger is a real <button> so it's reachable by Tab and operable
 *     with Enter/Space.
 *   - aria-describedby ties the trigger to the popover so screen readers
 *     announce the definition when the term receives focus.
 *   - aria-expanded reflects open/closed state.
 *   - Escape closes the popover and returns focus state to the trigger.
 *   - The popover is hidden from AT until opened (visibility: hidden) so
 *     it isn't read out twice when collapsed.
 *
 * Reusable: pass `term`, optional `partOfSpeech` (e.g. "noun"), and optional
 * `pronunciation` (e.g. "prōz"). The definition body is the default slot,
 * so callers can pass arbitrary inline markup.
 */

interface Props {
  term: string;
  partOfSpeech?: string;
  pronunciation?: string;
}

const { term, partOfSpeech, pronunciation } = Astro.props;

// Stable-ish id for aria-describedby. Math.random is fine since the id
// only needs to be unique within a single render of the page.
const popoverId = `def-${term.toLowerCase().replace(/[^a-z0-9]+/g, "-")}-${Math.random().toString(36).slice(2, 8)}`;
---

<span class="define">
  <button
    type="button"
    class="define-trigger"
    aria-describedby={popoverId}
    aria-expanded="false"
    data-define-trigger
  >
    {term}
  </button>
  <span
    class="define-card"
    id={popoverId}
    role="tooltip"
    data-define-card
  >
    <span class="define-header">
      <span class="define-term">{term}</span>
      {pronunciation && (
        <span class="define-pron" aria-label={`pronunciation: ${pronunciation}`}>
          | {pronunciation} |
        </span>
      )}
      {partOfSpeech && <span class="define-pos">{partOfSpeech}</span>}
    </span>
    <span class="define-body">
      <slot />
    </span>
  </span>
</span>

<script>
  // Two-state machine: { closed, open }. All transitions go through
  // setOpen so the DOM class, the aria attribute, and the local boolean
  // can never disagree. Inputs:
  //   - mouseenter / mouseleave on trigger or card → open / scheduled close
  //   - click on trigger                            → toggle
  //   - Escape inside wrap                          → close + refocus trigger
  //   - focusout from wrap                          → close (keyboard tab-away)
  //   - document click outside wrap                 → close
  //
  // We deliberately do NOT open on `focus`. On a touch tap the browser
  // fires `focus` before `click`; opening on focus and then toggling on
  // click closes the popover in the same gesture, so the user sees
  // nothing. Keyboard users open the popover the same way mouse users do
  // — they activate the button with Enter or Space, which dispatches a
  // click event.
  // Narrow-viewport breakpoint must stay in lockstep with the
  // `@media (max-width: 520px)` rule in the stylesheet below — the JS
  // only attaches viewport-change listeners when this matches so
  // scroll/resize don't close hover-opened cards on desktop.
  const mobileMQ = window.matchMedia("(max-width: 520px)");

  document.querySelectorAll<HTMLElement>(".define").forEach((wrap) => {
    const trigger = wrap.querySelector<HTMLButtonElement>("[data-define-trigger]");
    const card = wrap.querySelector<HTMLElement>("[data-define-card]");
    if (!trigger || !card) return;

    let isOpen = false;
    let pointerInside = false;
    let closeTimer: ReturnType<typeof setTimeout> | null = null;

    // Writes the trigger's current bottom edge (viewport-relative) to a
    // custom property the mobile CSS rule reads as its `top`. The card
    // is `position: fixed` on mobile so getBoundingClientRect's
    // viewport-relative coords are exactly what we need — no scroll
    // offset arithmetic. A small gap (8px) mirrors the desktop
    // `--space-2` spacing beneath the trigger. Called unconditionally
    // on open: on desktop the variable is unused (the desktop CSS uses
    // a static top), so it's free to always write.
    const applyMobileAnchor = () => {
      const rect = trigger.getBoundingClientRect();
      card.style.setProperty("--define-card-top", `${rect.bottom + 8}px`);
    };

    // Any viewport change while the card is open → close. The fixed
    // card can't reposition itself intelligently (it'd need to re-run
    // the anchor math on every scroll tick), and a stranded card above
    // or below its trigger reads as broken. Closing is the cleaner
    // mobile tooltip convention anyway.
    const handleViewportChange = () => setOpen(false);

    const setOpen = (next: boolean) => {
      if (isOpen === next) return;
      isOpen = next;
      if (next) {
        applyMobileAnchor();
        if (mobileMQ.matches) {
          window.addEventListener("scroll", handleViewportChange, { passive: true });
          window.addEventListener("resize", handleViewportChange);
        }
      } else {
        // Safe to call unconditionally — removeEventListener is a no-op
        // when the listener was never registered (desktop path).
        window.removeEventListener("scroll", handleViewportChange);
        window.removeEventListener("resize", handleViewportChange);
      }
      wrap.classList.toggle("is-open", next);
      trigger.setAttribute("aria-expanded", next ? "true" : "false");
    };

    const cancelClose = () => {
      if (closeTimer !== null) {
        clearTimeout(closeTimer);
        closeTimer = null;
      }
    };

    // 120ms grace lets the cursor travel trigger→card without the card
    // vanishing mid-hop. Re-entering during the grace cancels via
    // pointerInside, so the timer never fires a stale close.
    const scheduleClose = () => {
      cancelClose();
      closeTimer = setTimeout(() => {
        closeTimer = null;
        if (!pointerInside) setOpen(false);
      }, 120);
    };

    // Hover for mouse pointers only. We use pointerenter/pointerleave
    // (not mouseenter/mouseleave) so we can filter on pointerType: touch
    // and pen taps will fire synthesized mouseenter on most mobile
    // browsers, which would otherwise call setOpen(true) and then have
    // the immediately-following click toggle it back to closed — the
    // same race we already eliminated for `focus`. By gating on
    // pointerType === "mouse", touch taps go through the click path
    // exclusively, and hybrid devices (touchscreen laptops) still get
    // mouse-hover behavior when the user uses a trackpad.
    const onPointerEnter = (e: PointerEvent) => {
      if (e.pointerType !== "mouse") return;
      pointerInside = true;
      cancelClose();
      setOpen(true);
    };
    const onPointerLeave = (e: PointerEvent) => {
      if (e.pointerType !== "mouse") return;
      pointerInside = false;
      scheduleClose();
    };
    trigger.addEventListener("pointerenter", onPointerEnter);
    trigger.addEventListener("pointerleave", onPointerLeave);
    card.addEventListener("pointerenter", onPointerEnter);
    card.addEventListener("pointerleave", onPointerLeave);

    // Click toggles — covers touch (the only available path) and
    // keyboard (Enter/Space activates a focused button as a click).
    // preventDefault stops accidental form submits if the component is
    // ever placed inside a <form>.
    trigger.addEventListener("click", (e) => {
      e.preventDefault();
      cancelClose();
      setOpen(!isOpen);
    });

    // Escape closes and restores focus to the trigger.
    wrap.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && isOpen) {
        e.stopPropagation();
        setOpen(false);
        trigger.focus();
      }
    });

    // Keyboard tab-away closes. pointerInside is the escape hatch so
    // mouse users hovering the card don't see it close out from under
    // their cursor when the trigger blurs.
    wrap.addEventListener("focusout", (e) => {
      const next = e.relatedTarget;
      if (next instanceof Node && wrap.contains(next)) return;
      if (pointerInside) return;
      setOpen(false);
    });

    // Outside click closes. Early-returns when this instance is already
    // closed so the per-instance listener is effectively free to register.
    document.addEventListener("click", (e) => {
      if (!isOpen) return;
      if (e.target instanceof Node && wrap.contains(e.target)) return;
      setOpen(false);
    });
  });
</script>

<style>
  /* The wrapper is the positioning context for the absolutely-positioned
     card. Inline-block keeps it as part of the surrounding text flow so
     it works inside headings and paragraphs alike. */
  .define {
    position: relative;
    display: inline-block;
  }

  /* Reset all the chrome a <button> brings by default so it reads as a
     normal inline word, then add the dotted-underline cue that indicates
     "this is interactive". cursor: help is the conventional pointer for
     a defined term. */
  .define-trigger {
    background: none;
    border: none;
    padding: 0;
    margin: 0;
    font: inherit;
    color: inherit;
    cursor: help;
    text-decoration: underline dotted;
    text-decoration-thickness: 1px;
    text-underline-offset: 0.18em;
    text-decoration-color: var(--color-primary);
    transition: color 120ms ease, text-decoration-color 120ms ease;
  }

  /* The aria-expanded rule is unconditional — when the card is open we
     always want the trigger to indicate that state. The hover rule is
     gated on (hover: hover) so it only applies on devices that actually
     support hover; without the gate, a touch tap on mobile applies the
     darker teal "hover" state until the next tap elsewhere, which made
     the first tap on a definition look like it had succeeded (text
     darkened) even though the popover never opened. Pairs with the JS
     pointerType === "mouse" filter on the hover handlers. */
  .define-trigger[aria-expanded="true"] {
    color: var(--color-primary);
  }

  @media (hover: hover) {
    .define-trigger:hover {
      color: var(--color-primary);
    }
  }

  .define-trigger:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 4px;
    border-radius: 2px;
  }

  /* The card sits in absolute flow under the trigger. z-index high enough
     to clear sibling content but not the page nav. max-width keeps long
     definitions from spreading across the whole viewport. */
  .define-card {
    position: absolute;
    top: calc(100% + var(--space-2));
    left: 0;
    z-index: 50;
    /* Inline-block so the card auto-sizes to its content up to max-width. */
    display: block;
    width: max-content;
    max-width: min(320px, calc(100vw - var(--space-8)));

    padding: var(--space-3) var(--space-4);
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.12);

    /* Reset typography so a card opened from inside a large heading
       still reads at body size. */
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 400;
    line-height: 1.5;
    letter-spacing: 0;
    color: var(--color-text);
    text-align: left;
    white-space: normal;

    /* Hidden until .is-open is applied. `display: none` (not just
       `visibility: hidden`) is critical: when a definition trigger
       wraps near the right edge of a narrow viewport, the card's
       absolutely-positioned box extends past the viewport. With
       `visibility: hidden` the box still contributes to the page's
       scrolling area, which on iOS Safari produces a phantom gap
       to the right of the layout viewport (the html-level
       `overflow-x: clip` backstop in base.css doesn't fully contain
       abspos descendants on iOS). `display: none` removes the
       layout box entirely so the popover can never widen the page
       when closed. The fade-in/out animation is preserved via
       `transition-behavior: allow-discrete` + `@starting-style` for
       browsers that support them; older browsers degrade to an
       instant show/hide. */
    display: none;
    opacity: 0;
    pointer-events: none;
    transform: translateY(-2px);
    transition:
      opacity 140ms ease,
      transform 140ms ease,
      display 140ms allow-discrete;
  }

  .define.is-open .define-card {
    display: block;
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
  }

  /* @starting-style sets the from-state for the open transition so
     the fade-in actually animates from opacity: 0 / translateY(-2px)
     instead of jumping straight to fully visible the first time the
     card appears. Browsers without support skip this rule and the
     card simply appears instantly — still no overflow regression. */
  @starting-style {
    .define.is-open .define-card {
      opacity: 0;
      transform: translateY(-2px);
    }
  }

  .define-header {
    display: flex;
    align-items: baseline;
    gap: var(--space-2);
    flex-wrap: wrap;
    margin-bottom: var(--space-2);
    padding-bottom: var(--space-2);
    border-bottom: 1px solid var(--color-border);
  }

  .define-term {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: var(--text-base);
    color: var(--color-text);
  }

  .define-pron {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  .define-pos {
    font-style: italic;
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  .define-body {
    display: block;
    color: var(--color-text-muted);
  }

  /* Inline <code> inside the definition body — used to show example
     syntax like **bold** or \frac{a}{b}. The codebase doesn't define
     a global inline code style (only scoped variants such as
     .atto-doc code), so we mirror the same recipe here so example
     snippets read as code snippets and not as muted prose. */
  .define-body :global(code) {
    font-family: var(--font-mono);
    font-size: 0.92em;
    padding: 0.05em 0.3em;
    background: var(--color-code-bg);
    border: 1px solid var(--color-border);
    color: var(--color-text);
    /* Don't let a long token push the card past its max-width. */
    word-break: break-word;
  }

  /* Right-edge clip avoidance for desktop: when the trigger is near the
     right edge of its container, anchor the card to the right of the
     trigger instead. Authors opt in via [data-align="right"]. The mobile
     rule below overrides this because it's equally specific and comes
     later in source order. */
  .define[data-align="right"] .define-card {
    left: auto;
    right: 0;
  }

  /* Narrow viewports: detach the card from the trigger's x-position and
     float it centered within the viewport's inline padding, still pinned
     to the trigger's bottom on the y-axis. Rationale: anchoring the card
     to the trigger's left edge consistently pushed it off the right side
     of the viewport whenever a defined word wrapped to the right half of
     a line — a problem that no amount of max-width clamping can fix
     because `left: 0` of a right-edge trigger + any non-zero width
     already overflows. Using position: fixed with inline insets gives
     the card a stable viewport-relative box regardless of where the
     trigger sits in the flow, and a CSS custom property set from JS
     (`--define-card-top`) keeps the card visually tethered to the
     defined word's baseline. Viewport changes (scroll, resize) close
     the card so it never gets stranded mid-page. */
  @media (max-width: 520px) {
    .define .define-card {
      position: fixed;
      top: var(--define-card-top, auto);
      left: var(--space-4);
      right: var(--space-4);
      width: auto;
      max-width: none;
    }
  }
</style>
