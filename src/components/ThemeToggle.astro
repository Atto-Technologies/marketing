---
// Theme toggle — owns both the UI shell AND the script that reads/writes
// `data-theme` on <html> and persists to localStorage. The pre-paint script
// that prevents FOUC still lives in Base.astro because it must run before
// component scripts, but everything user-interactive lives here.
---
<button
  type="button"
  data-theme-toggle
  aria-label="Toggle theme"
  class="theme-toggle"
>
  <svg
    width="18"
    height="18"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
    focusable="false"
  >
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
  </svg>
</button>

<script>
  const SUN =
    '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>';
  const MOON =
    '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>';

  const root = document.documentElement;
  const toggle = document.querySelector<HTMLButtonElement>('[data-theme-toggle]');
  if (toggle) {
    const apply = (theme: 'light' | 'dark') => {
      root.setAttribute('data-theme', theme);
      toggle.innerHTML = theme === 'dark' ? SUN : MOON;
      toggle.setAttribute(
        'aria-label',
        'Switch to ' + (theme === 'dark' ? 'light' : 'dark') + ' mode',
      );
    };

    const current = root.getAttribute('data-theme') === 'dark' ? 'dark' : 'light';
    apply(current);

    toggle.addEventListener('click', () => {
      const next = root.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
      try {
        localStorage.setItem('atto-theme', next);
      } catch (e) {
        // Ignore storage errors (private mode, quota exceeded).
      }
      apply(next);
    });
  }
</script>

<style>
  /* Sized to match hamburger (44×44) for consistent tap targets on mobile. */
  .theme-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    padding: 0;
    color: var(--color-text-muted);
    background: none;
    border: 1px solid var(--color-border);
  }

  .theme-toggle:hover {
    color: var(--color-text);
    border-color: var(--color-text-muted);
  }
</style>
