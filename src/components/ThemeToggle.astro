---
// Theme toggle — icon swap + aria label are managed by the inline
// script in Base.astro, which reads/writes data-theme on <html>.
---
<button
  type="button"
  data-theme-toggle
  aria-label="Toggle theme"
  class="theme-toggle"
>
  <svg
    width="18"
    height="18"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
    focusable="false"
  >
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
  </svg>
</button>

<style>
  .theme-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    padding: 0;
    color: var(--color-text-muted);
    background: none;
    border: 1px solid var(--color-border);
  }

  .theme-toggle:hover {
    color: var(--color-text);
    border-color: var(--color-text-muted);
  }
</style>
