---
export interface Props {
  filename: string;
  label?: string;
  defaultTab?: 'rendered' | 'source';
}

const { filename, label, defaultTab = 'rendered' } = Astro.props;

// Unique id per render so multiple instances can coexist with valid aria.
const uid = Math.random().toString(36).slice(2, 10);
const renderedPanelId = `atto-panel-${uid}-rendered`;
const sourcePanelId = `atto-panel-${uid}-source`;
const renderedTabId = `atto-tab-${uid}-rendered`;
const sourceTabId = `atto-tab-${uid}-source`;

const renderedDefault = defaultTab === 'rendered';
---
<div class="atto-demo" data-atto-demo>
  <div class="atto-demo-head">
    {label && <span class="atto-demo-label">{label}</span>}
    <div class="atto-demo-tabs" role="tablist" aria-label={`${filename} — view mode`}>
      <button
        type="button"
        role="tab"
        id={renderedTabId}
        data-atto-tab="rendered"
        aria-selected={renderedDefault}
        aria-controls={renderedPanelId}
        tabindex={renderedDefault ? 0 : -1}
      >Rendered</button>
      <button
        type="button"
        role="tab"
        id={sourceTabId}
        data-atto-tab="source"
        aria-selected={!renderedDefault}
        aria-controls={sourcePanelId}
        tabindex={renderedDefault ? -1 : 0}
      >Source</button>
    </div>
    <span class="atto-demo-filename">{filename}</span>
  </div>

  <div class="atto-demo-body">
    <div
      role="tabpanel"
      id={renderedPanelId}
      data-atto-panel="rendered"
      aria-labelledby={renderedTabId}
      hidden={!renderedDefault}
    >
      <slot name="rendered" />
    </div>
    <div
      role="tabpanel"
      id={sourcePanelId}
      data-atto-panel="source"
      aria-labelledby={sourceTabId}
      hidden={renderedDefault}
    >
      <slot name="source" />
    </div>
  </div>
</div>

<script>
  // Scoped per-instance tab switching.
  document.querySelectorAll<HTMLElement>('[data-atto-demo]').forEach((root) => {
    const tabs = root.querySelectorAll<HTMLButtonElement>('[data-atto-tab]');
    const panels = root.querySelectorAll<HTMLElement>('[data-atto-panel]');

    function activate(name: 'rendered' | 'source') {
      tabs.forEach((tab) => {
        const match = tab.dataset.attoTab === name;
        tab.setAttribute('aria-selected', String(match));
        tab.tabIndex = match ? 0 : -1;
      });
      panels.forEach((panel) => {
        panel.hidden = panel.dataset.attoPanel !== name;
      });
    }

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        const name = tab.dataset.attoTab;
        if (name === 'rendered' || name === 'source') activate(name);
      });

      tab.addEventListener('keydown', (e) => {
        if (e.key !== 'ArrowLeft' && e.key !== 'ArrowRight') return;
        e.preventDefault();
        const next = tab.dataset.attoTab === 'rendered' ? 'source' : 'rendered';
        activate(next);
        const target = root.querySelector<HTMLButtonElement>(
          `[data-atto-tab="${next}"]`,
        );
        target?.focus();
      });
    });
  });
</script>

<style>
  .atto-demo {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--color-border);
    background: var(--color-bg);
  }

  .atto-demo-head {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-2) var(--space-4);
    border-bottom: 1px solid var(--color-border);
    background: var(--color-surface);
    min-height: 40px;
  }

  .atto-demo-label {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-primary);
  }

  .atto-demo-tabs {
    display: flex;
    gap: 0;
  }

  .atto-demo-tabs button {
    padding: var(--space-2) var(--space-4);
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.04em;
    color: var(--color-text-muted);
    background: none;
    border: none;
    border-bottom: 2px solid transparent;
    cursor: pointer;
    margin-bottom: -1px;
  }

  .atto-demo-tabs button:hover {
    color: var(--color-text);
  }

  .atto-demo-tabs button[aria-selected="true"] {
    color: var(--color-text);
    border-bottom-color: var(--color-primary);
  }

  .atto-demo-filename {
    margin-left: auto;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  .atto-demo-body {
    display: flex;
    flex-direction: column;
  }

  .atto-demo-body [role="tabpanel"] {
    min-height: 0;
  }

  /* Ensure inner pre fills panel without collapsing margins. */
  .atto-demo-body :global(.code-block) {
    border: none;
    border-left: 3px solid var(--color-primary);
  }

  @media (max-width: 520px) {
    .atto-demo-filename {
      display: none;
    }
  }
</style>
