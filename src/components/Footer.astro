---
// Footer links are intentionally limited to pages that actually exist.
// Placeholder hash routes have been removed to avoid broken anchors.
const product = [
  { href: '/product', label: 'Product' },
  { href: '/pricing', label: 'Pricing' },
  { href: '/waitlist', label: 'Waitlist' },
];

const docs = [
  { href: '/docs', label: 'Syntax Spec' },
  { href: '/docs#directives', label: 'Directives' },
  { href: '/docs#ast-mapping', label: 'Abstract Syntax Tree' },
  { href: '/apply', label: 'Hosted Registry' },
  { href: 'mailto:registry@atto.tech?subject=AFRP%20Tier%201%20Inquiry', label: 'Tier 1 inquiry' },
];

const company = [
  { href: 'mailto:hello@atto.tech', label: 'Contact' },
  { href: 'mailto:sales@atto.tech', label: 'Sales' },
];
---
<footer class="site-footer">
  <div class="footer-inner wrap">
    <div class="brand-col">
      <a href="/" class="brand" aria-label="Atto home">
        <svg
          viewBox="0 0 32 32"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
          role="img"
          aria-hidden="true"
          focusable="false"
          width="24"
          height="24"
        >
          <rect x="4" y="4" width="16" height="16" stroke="currentColor" stroke-width="2.5" fill="none" />
          <line x1="20" y1="12" x2="20" y2="28" stroke="currentColor" stroke-width="2.5" />
        </svg>
        <span class="wordmark">atto</span>
      </a>
      <p class="tagline">
        Structured documents for high-stakes work.
      </p>
    </div>

    <nav class="footer-nav" aria-label="Product">
      <h3>Product</h3>
      <ul role="list">
        {product.map(({ href, label }) => (
          <li><a href={href}>{label}</a></li>
        ))}
      </ul>
    </nav>

    <nav class="footer-nav" aria-label="Docs">
      <h3>Docs</h3>
      <ul role="list">
        {docs.map(({ href, label }) => (
          <li><a href={href}>{label}</a></li>
        ))}
      </ul>
    </nav>

    <nav class="footer-nav" aria-label="Company">
      <h3>Company</h3>
      <ul role="list">
        {company.map(({ href, label }) => (
          <li><a href={href}>{label}</a></li>
        ))}
      </ul>
    </nav>
  </div>

  <div class="footer-bottom wrap">
    <span class="copyright">© 2026 Atto Technologies Inc.</span>
    <span class="build-meta">Syntax v0 · pre-launch</span>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-border);
    margin-top: var(--space-32);
    background: var(--color-bg);
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: var(--space-12);
    padding-block: var(--space-16);
  }

  .brand-col {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    max-width: 320px;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    color: var(--color-text);
    text-decoration: none;
  }

  .brand .wordmark {
    font-family: var(--font-display);
    font-size: var(--text-base);
    font-weight: 800;
    letter-spacing: -0.01em;
    line-height: 1;
  }

  .tagline {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    max-width: 28ch;
  }

  .footer-nav h3 {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text);
    margin-bottom: var(--space-4);
  }

  .footer-nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .footer-nav a {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    text-decoration: none;
  }

  .footer-nav a:hover {
    color: var(--color-text);
  }

  .footer-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    padding-block: var(--space-6);
    border-top: 1px solid var(--color-border);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  .copyright,
  .build-meta {
    font-size: var(--text-xs);
  }

  .build-meta {
    font-family: var(--font-mono);
    color: var(--color-text-muted);
  }

  @media (max-width: 768px) {
    .footer-inner {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-8);
    }

    .brand-col {
      grid-column: 1 / -1;
    }

    .footer-bottom {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
