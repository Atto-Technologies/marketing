---
import ThemeToggle from './ThemeToggle.astro';

const links = [
  { href: '/product', label: 'Product' },
  { href: '/docs', label: 'Docs' },
  { href: '/pricing', label: 'Pricing' },
];

// Normalize path for active-link matching: trailing slash insensitive,
// prefix match so /docs#section still highlights "Docs".
const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
const isActive = (href: string): boolean => {
  const normalized = href.replace(/\/$/, '') || '/';
  if (normalized === '/') return pathname === '/';
  return pathname === normalized || pathname.startsWith(`${normalized}/`);
};
---
<nav class="site-nav" aria-label="Primary">
  {/* Outer <nav> provides the full-width sticky bar + border; .nav-inner
     constrains the actual layout to the site content width so the brand,
     links, and CTAs align with page content below. */}
  <div class="nav-inner">
    <a href="/" class="brand" aria-label="Atto home">
      <svg
        viewBox="0 0 32 32"
        fill="none"
        xmlns="http://www.w3.org/2000/svg"
        role="img"
        aria-hidden="true"
        focusable="false"
        width="28"
        height="28"
      >
        <rect x="4" y="4" width="16" height="16" stroke="currentColor" stroke-width="2.5" fill="none" />
        <line x1="20" y1="12" x2="20" y2="28" stroke="currentColor" stroke-width="2.5" />
      </svg>
      <span class="wordmark">atto</span>
    </a>

    <ul class="nav-links" role="list">
      {links.map(({ href, label }) => {
        const active = isActive(href);
        return (
          <li>
            <a
              href={href}
              aria-current={active ? 'page' : undefined}
              data-active={active ? 'true' : undefined}
            >{label}</a>
          </li>
        );
      })}
    </ul>

    <div class="nav-actions">
      <ThemeToggle />
      <a href="/waitlist" class="nav-cta">
        Join waitlist
        <span aria-hidden="true">→</span>
      </a>
      <button
        type="button"
        class="nav-hamburger"
        data-nav-toggle
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-nav-panel"
      >
        <svg
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          aria-hidden="true"
          focusable="false"
        >
          <line x1="3" y1="7" x2="21" y2="7" />
          <line x1="3" y1="12" x2="21" y2="12" />
          <line x1="3" y1="17" x2="21" y2="17" />
        </svg>
      </button>
    </div>
  </div>

  <div id="mobile-nav-panel" class="mobile-panel" hidden>
    <ul role="list">
      {links.map(({ href, label }) => {
        const active = isActive(href);
        return (
          <li>
            <a
              href={href}
              aria-current={active ? 'page' : undefined}
              data-active={active ? 'true' : undefined}
            >{label}</a>
          </li>
        );
      })}
      <li>
        <a href="/waitlist" class="mobile-cta">
          Join waitlist
          <span aria-hidden="true">→</span>
        </a>
      </li>
    </ul>
  </div>
</nav>

<script>
  const toggle = document.querySelector<HTMLButtonElement>('[data-nav-toggle]');
  const panel = document.getElementById('mobile-nav-panel');

  // Cache focusable elements inside the panel for the focus trap.
  const getFocusable = (): HTMLElement[] => {
    if (!panel) return [];
    return Array.from(
      panel.querySelectorAll<HTMLElement>(
        'a[href], button:not([disabled]), [tabindex]:not([tabindex="-1"])',
      ),
    );
  };

  function closePanel() {
    if (!toggle || !panel) return;
    toggle.setAttribute('aria-expanded', 'false');
    toggle.setAttribute('aria-label', 'Open menu');
    panel.hidden = true;
    // Release scroll lock.
    document.documentElement.style.overflow = '';
    document.body.style.overflow = '';
    // Return focus to the trigger so keyboard users don't lose their place.
    toggle.focus();
  }

  function openPanel() {
    if (!toggle || !panel) return;
    toggle.setAttribute('aria-expanded', 'true');
    toggle.setAttribute('aria-label', 'Close menu');
    panel.hidden = false;
    // Lock scroll on both elements — iOS Safari needs both.
    document.documentElement.style.overflow = 'hidden';
    document.body.style.overflow = 'hidden';
    // Move focus to the first link so the menu is keyboard-navigable immediately.
    const [first] = getFocusable();
    first?.focus();
  }

  toggle?.addEventListener('click', () => {
    const expanded = toggle.getAttribute('aria-expanded') === 'true';
    if (expanded) closePanel();
    else openPanel();
  });

  // Close when a link inside the panel is clicked.
  panel?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => closePanel());
  });

  // Keyboard handling: Escape closes; Tab wraps focus within the panel.
  document.addEventListener('keydown', (e) => {
    if (!panel || panel.hidden) return;
    if (e.key === 'Escape') {
      e.preventDefault();
      closePanel();
      return;
    }
    if (e.key !== 'Tab') return;
    const focusable = getFocusable();
    if (focusable.length === 0) return;
    const first = focusable[0];
    const last = focusable[focusable.length - 1];
    const active = document.activeElement as HTMLElement | null;
    if (e.shiftKey && active === first) {
      e.preventDefault();
      last.focus();
    } else if (!e.shiftKey && active === last) {
      e.preventDefault();
      first.focus();
    }
  });

  // Reset on viewport resize above breakpoint.
  const mql = window.matchMedia('(min-width: 768px)');
  mql.addEventListener('change', (e) => {
    if (e.matches) closePanel();
  });
</script>

<style>
  /* Outer bar — full-viewport-width sticky surface + bottom border. */
  .site-nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
  }

  /* Inner row — content-width constrained so the nav aligns with page
     wrappers (.wrap / .wrap-default) used in every page below it. */
  .nav-inner {
    max-width: var(--content-wide);
    margin-inline: auto;
    padding: var(--space-4) var(--space-8);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-8);
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: var(--space-3);
    color: var(--color-text);
    text-decoration: none;
  }

  .brand .wordmark {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 800;
    letter-spacing: -0.01em;
    line-height: 1;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: var(--space-8);
    margin: 0;
    padding: 0;
  }

  .nav-links a {
    position: relative;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--color-text-muted);
    text-decoration: none;
    padding-block: var(--space-1);
  }

  .nav-links a:hover {
    color: var(--color-text);
  }

  /* Active page indicator — 2px underline anchored to the primary color. */
  .nav-links a[aria-current="page"] {
    color: var(--color-text);
  }

  .nav-links a[aria-current="page"]::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -2px;
    height: 2px;
    background: var(--color-primary);
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  /* Pinned to the same 44×44 control height as .theme-toggle and .nav-hamburger
     so the three controls line up pixel-for-pixel across the top of the bar. */
  .nav-cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    height: 44px;
    padding-inline: var(--space-5);
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--color-on-primary);
    background: var(--color-primary);
    border: 1px solid var(--color-primary);
    text-decoration: none;
    line-height: 1;
  }

  .nav-cta:hover {
    background: var(--color-primary-hover);
    border-color: var(--color-primary-hover);
  }

  /* Hamburger sized to the WCAG 2.5.5 AAA / iOS HIG 44×44 minimum tap target. */
  .nav-hamburger {
    display: none;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
  }

  .nav-hamburger:hover {
    color: var(--color-text);
    border-color: var(--color-text-muted);
  }

  .mobile-panel {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    background: var(--color-bg);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .mobile-panel ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .mobile-panel a {
    display: block;
    padding: var(--space-4) var(--space-8);
    font-family: var(--font-body);
    font-size: var(--text-base);
    font-weight: 500;
    color: var(--color-text);
    text-decoration: none;
    border-bottom: 1px solid var(--color-border);
  }

  .mobile-panel a:hover {
    background: var(--color-surface);
  }

  .mobile-panel a[aria-current="page"] {
    color: var(--color-primary);
    background: var(--color-surface);
  }

  .mobile-panel li:last-child a {
    border-bottom: none;
  }

  .mobile-panel .mobile-cta {
    color: var(--color-primary);
    font-weight: 700;
  }

  @media (max-width: 768px) {
    .nav-inner {
      padding-inline: var(--space-5);
    }

    .nav-links,
    .nav-cta {
      display: none;
    }

    .nav-hamburger {
      display: inline-flex;
    }
  }
</style>
