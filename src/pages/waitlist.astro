---
import Base from '../layouts/Base.astro';

// Benefits shown beneath the form. Edited as data so the structure is
// explicit and easy to reorder.
const beacons = [
  {
    title: 'Pre-launch updates',
    body: 'Short, low-frequency emails as the format and editor evolve. No cold sales outreach.',
  },
  {
    title: 'Priority early access',
    body: 'Waitlist members get the first private-beta invites, ordered by signup time.',
  },
  {
    title: 'Founding-member pricing',
    body: 'Locked-in Solo and Team pricing for anyone who activates during the private beta.',
  },
];
---
<Base
  title="Waitlist"
  description="Join the Atto waitlist for pre-launch updates, priority early access, and founding-member pricing."
>
  <section class="waitlist wrap-narrow">
    <p class="eyebrow">Waitlist</p>
    <h1>Join the waitlist.</h1>
    <p class="lede">
      Atto is pre-launch. The format is stable; the editor and signing pipeline
      are in private beta. Add yourself below and we&rsquo;ll reach out when a
      seat opens.
    </p>

    {/* ─── Form ────────────────────────────────────────────────── */}
    <form class="wait-form" data-waitlist-form novalidate>
      <div class="wait-field">
        <label for="wait-email" class="wait-label">
          Work email
          <span class="wait-required" aria-hidden="true">*</span>
        </label>
        <input
          id="wait-email"
          name="email"
          type="email"
          class="wait-input"
          placeholder="you@company.com"
          autocomplete="email"
          required
          aria-describedby="wait-email-error"
        />
        <p class="wait-error" id="wait-email-error" data-waitlist-error hidden>
          Please enter a valid email address.
        </p>
      </div>

      <div class="wait-field">
        <label for="wait-plan" class="wait-label">
          Which plan fits? <span class="wait-optional">Optional</span>
        </label>
        <select id="wait-plan" name="plan" class="wait-input" data-waitlist-plan>
          <option value="">No preference yet</option>
          <option value="solo">Solo — individual author</option>
          <option value="team">Team — up to 10 collaborators</option>
          <option value="enterprise">Enterprise — compliance &amp; SSO</option>
        </select>
      </div>

      <div class="wait-field">
        <label for="wait-use" class="wait-label">
          What will you use Atto for? <span class="wait-optional">Optional</span>
        </label>
        <textarea
          id="wait-use"
          name="use_case"
          class="wait-input wait-textarea"
          rows="3"
          placeholder="Contracts, term sheets, research reports…"
        ></textarea>
      </div>

      <p class="wait-legal">
        We&rsquo;ll use your address to contact you about the private beta and
        nothing else. Submitting opens your mail client with a pre-filled message
        to <code>hello@atto.tech</code>.
      </p>

      <button type="submit" class="btn btn-primary wait-submit">
        Join waitlist
        <span aria-hidden="true">→</span>
      </button>
    </form>

    {/* ─── Success state ───────────────────────────────────────── */}
    <div
      class="wait-success"
      data-waitlist-success
      role="status"
      aria-live="polite"
      hidden
    >
      <p class="eyebrow">Thank you</p>
      <h2>Your mail client should have opened.</h2>
      <p>
        Send the pre-filled message as-is and you&rsquo;re on the list. If your
        client didn&rsquo;t launch, email us directly at
        <a href="mailto:hello@atto.tech">hello@atto.tech</a>.
      </p>
    </div>

    {/* ─── What you'll get ─────────────────────────────────────── */}
    <div class="wait-beacons">
      <p class="eyebrow">What you&rsquo;ll get</p>
      <ul role="list">
        {beacons.map(({ title, body }) => (
          <li>
            <h3>{title}</h3>
            <p>{body}</p>
          </li>
        ))}
      </ul>
    </div>
  </section>
</Base>

<script>
  // Waitlist form — no backend. Submission constructs a mailto: URL with the
  // typed email, chosen plan, and use case in the body, then opens the user's
  // mail client. Progressive enhancement: without JS the form does nothing
  // (the submit button is a plain button), so the legal copy calls this out
  // explicitly.
  const form = document.querySelector<HTMLFormElement>('[data-waitlist-form]');
  const success = document.querySelector<HTMLElement>('[data-waitlist-success]');
  const errorEl = document.querySelector<HTMLElement>('[data-waitlist-error]');
  const planSelect = document.querySelector<HTMLSelectElement>('[data-waitlist-plan]');

  // Pre-fill plan from ?plan=... query param so the pricing page can funnel
  // each tier to the right default.
  if (planSelect) {
    const params = new URLSearchParams(window.location.search);
    const plan = params.get('plan');
    if (plan && ['solo', 'team', 'enterprise'].includes(plan)) {
      planSelect.value = plan;
    }
  }

  const EMAIL_RE = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

  function showError(message: string) {
    if (!errorEl) return;
    errorEl.textContent = message;
    errorEl.hidden = false;
  }

  function clearError() {
    if (!errorEl) return;
    errorEl.hidden = true;
    errorEl.textContent = '';
  }

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    clearError();

    const data = new FormData(form);
    const email = String(data.get('email') ?? '').trim();
    const plan = String(data.get('plan') ?? '').trim();
    const useCase = String(data.get('use_case') ?? '').trim();

    if (!EMAIL_RE.test(email)) {
      showError('Please enter a valid email address.');
      (form.elements.namedItem('email') as HTMLInputElement | null)?.focus();
      return;
    }

    // Build the mailto body from the submitted fields. Line breaks via %0A.
    const lines = [`Email: ${email}`];
    if (plan) lines.push(`Plan: ${plan}`);
    if (useCase) lines.push('', 'Use case:', useCase);

    const subject = encodeURIComponent('Waitlist signup');
    const body = encodeURIComponent(lines.join('\n'));
    const href = `mailto:hello@atto.tech?subject=${subject}&body=${body}`;

    // Reveal success state before launching the mail client so users always
    // see confirmation even if the client fails to open.
    if (success) success.hidden = false;
    form.hidden = true;

    window.location.href = href;
  });
</script>

<style>
  .waitlist {
    padding-block: var(--space-16) var(--space-24);
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  .waitlist h1 {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: var(--text-3xl);
    letter-spacing: -0.02em;
    margin-block: var(--space-4) var(--space-2);
  }

  .waitlist .lede {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    max-width: 56ch;
  }

  /* ─── Form ─────────────────────────────────────────────────── */

  .wait-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    padding: var(--space-8);
    border: 1px solid var(--color-border);
    border-left: 3px solid var(--color-primary);
    background: var(--color-surface);
  }

  .wait-field {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .wait-label {
    display: flex;
    align-items: baseline;
    gap: var(--space-2);
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text);
  }

  .wait-required {
    color: var(--color-primary);
  }

  .wait-optional {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: none;
    color: var(--color-text-muted);
  }

  .wait-input {
    padding: var(--space-3) var(--space-4);
    font-family: var(--font-body);
    font-size: var(--text-base);
    color: var(--color-text);
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    appearance: none;
  }

  .wait-input:focus {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
    border-color: var(--color-primary);
  }

  .wait-input::placeholder {
    color: var(--color-text-faint);
  }

  .wait-textarea {
    resize: vertical;
    min-height: 84px;
    line-height: 1.5;
  }

  .wait-error {
    font-size: var(--text-xs);
    color: #B5651D;
    margin: 0;
  }

  .wait-legal {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    line-height: 1.6;
    max-width: none;
  }

  .wait-legal code {
    font-family: var(--font-mono);
    font-size: 0.95em;
    padding: 0.05em 0.3em;
    background: var(--color-code-bg);
    border: 1px solid var(--color-border);
    color: var(--color-text);
  }

  .wait-submit {
    align-self: flex-start;
    justify-content: space-between;
  }

  /* ─── Success state ────────────────────────────────────────── */

  .wait-success {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding: var(--space-8);
    border: 1px solid var(--color-primary);
    border-left: 3px solid var(--color-primary);
    background: color-mix(in oklch, var(--color-primary) 6%, var(--color-surface));
  }

  .wait-success h2 {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: var(--text-xl);
    margin-block: var(--space-2) 0;
  }

  .wait-success p {
    font-size: var(--text-base);
    color: var(--color-text);
    max-width: 60ch;
  }

  .wait-success a {
    color: var(--color-primary);
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }

  /* ─── Beacons (what you'll get) ────────────────────────────── */

  .wait-beacons {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    padding-top: var(--space-8);
    border-top: 1px solid var(--color-border);
  }

  .wait-beacons ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-8);
  }

  .wait-beacons li {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    max-width: none;
  }

  .wait-beacons h3 {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--text-base);
    color: var(--color-text);
  }

  .wait-beacons p {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  @media (max-width: 720px) {
    .wait-beacons ul {
      grid-template-columns: 1fr;
      gap: var(--space-6);
    }

    .wait-form {
      padding: var(--space-6);
    }
  }
</style>
