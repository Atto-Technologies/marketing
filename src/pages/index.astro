---
import Base from '../layouts/Base.astro';
import { X } from '@lucide/astro';
import AttoDemo from '../components/AttoDemo.astro';
import LayerDemo from '../components/LayerDemo.astro';
import SignatureWidget from '../components/SignatureWidget.astro';
import DefineTerm from '../components/DefineTerm.astro';

const lifecycle = [
  { name: 'Draft', desc: 'Authors compose and revise.' },
  { name: 'Review', desc: 'Comments anchor to the AST.' },
  { name: 'Sign', desc: 'Parties countersign in order.' },
  { name: 'Freeze', desc: 'Content becomes immutable.' },
  { name: 'Execute', desc: 'Protocol events fire on effect.' },
];

// ─── Section 6 — Comparison matrix ────────────────────────────────
//
// 10 capability dimensions × 6 tools. Atto is the only tool with ✓
// across every row. Two rows (Executable math frozen at signing,
// Native :::credit-check directive) are unique to Atto — no other
// tool has even a partial mark, so we visually highlight those rows.
//
// Data shape:
//   compareTools  — column headers (Atto first; rest in displacement order)
//   compareRows   — feature rows; cells[] is parallel to compareTools[]
//                   each cell: { v: 'y'|'p'|'n', fn?: '<noteId>' }
//   compareNotes  — footnotes for partial (⚠) cells, rendered below the
//                   table. Numbered automatically by position.

// Cell value: y = native, p = partial (with footnote), n = not supported.
type CellValue = 'y' | 'p' | 'n';

interface CompareCell {
  v: CellValue;
  // Only populated on 'p' cells; references compareNotes[].id.
  fn?: string;
}

interface CompareRow {
  feature: string;
  // Length must equal compareTools.length, in the same column order.
  cells: CompareCell[];
  // True for rows where Atto is the only ✓ — used to tint the row.
  uniqueAtto?: boolean;
}

interface CompareNote {
  id: string;
  text: string;
}

const compareTools: string[] = [
  'Atto',
  'Word / Google Docs',
  'LaTeX / Markdown',
  'Notion',
  'DocuSign',
  'Ironclad',
];

const compareRows: CompareRow[] = [
  {
    feature: 'Human-readable source format',
    cells: [{ v: 'y' }, { v: 'n' }, { v: 'y' }, { v: 'n' }, { v: 'n' }, { v: 'n' }],
  },
  {
    feature: 'Human-writable without special tools',
    cells: [{ v: 'y' }, { v: 'p', fn: 'fn-blob' }, { v: 'y' }, { v: 'p', fn: 'fn-block' }, { v: 'n' }, { v: 'n' }],
  },
  {
    feature: 'Dedicated authoring editor',
    cells: [{ v: 'y' }, { v: 'y' }, { v: 'n' }, { v: 'y' }, { v: 'n' }, { v: 'y' }],
  },
  {
    feature: 'Hash-chained version history',
    cells: [{ v: 'y' }, { v: 'p', fn: 'fn-tracked' }, { v: 'p', fn: 'fn-git' }, { v: 'n' }, { v: 'n' }, { v: 'p', fn: 'fn-audit' }],
  },
  {
    feature: 'Cryptographic version integrity',
    cells: [{ v: 'y' }, { v: 'n' }, { v: 'n' }, { v: 'n' }, { v: 'p', fn: 'fn-pdf' }, { v: 'p', fn: 'fn-audit' }],
  },
  {
    feature: 'Signature execution',
    cells: [{ v: 'y' }, { v: 'n' }, { v: 'n' }, { v: 'n' }, { v: 'y' }, { v: 'y' }],
  },
  {
    feature: 'Signatures bound to content hash',
    cells: [{ v: 'y' }, { v: 'n' }, { v: 'n' }, { v: 'n' }, { v: 'p', fn: 'fn-sigbind' }, { v: 'p', fn: 'fn-sigbind' }],
  },
  {
    feature: 'Embedded math computation',
    cells: [{ v: 'y' }, { v: 'n' }, { v: 'y' }, { v: 'n' }, { v: 'n' }, { v: 'n' }],
  },
  {
    feature: 'Executable math (frozen at signing)',
    cells: [{ v: 'y' }, { v: 'n' }, { v: 'n' }, { v: 'n' }, { v: 'n' }, { v: 'n' }],
    uniqueAtto: true,
  },
  {
    feature: 'Native :::credit-check directive',
    cells: [{ v: 'y' }, { v: 'n' }, { v: 'n' }, { v: 'n' }, { v: 'n' }, { v: 'n' }],
    uniqueAtto: true,
  },
];

const compareNotes: CompareNote[] = [
  { id: 'fn-blob', text: 'Files are stored as proprietary binary or XML; portable only through the application, not as plain text.' },
  { id: 'fn-block', text: 'Notion uses a proprietary block model accessible only through its app or API.' },
  { id: 'fn-tracked', text: 'Track Changes is a UI-level marker (lost on export); Google Docs version history is server-side and not cryptographically verifiable. Neither produces a portable hash chain.' },
  { id: 'fn-git', text: 'Git provides hash-chained history alongside LaTeX/Markdown, but as an external tool, not a native property of the format itself.' },
  { id: 'fn-audit', text: 'Server-side audit log, not a portable cryptographic chain embedded in the document.' },
  { id: 'fn-pdf', text: 'DocuSign signs a PDF snapshot. The signature is on rendered output, not on a structured content hash of the source.' },
  { id: 'fn-sigbind', text: 'Signature attaches at sign time but with no cryptographic binding to a deterministic content hash. The document can be re-exported or reformatted without invalidating the signature.' },
];

// Visual + a11y mapping for the three cell states.
const compareSymbols = {
  y: { glyph: '✓', label: 'Yes: native, built into the core product.' },
  p: { glyph: '⚠', label: 'Partial: appended externally, lacks structural integrity, or requires another tool.' },
  n: { glyph: '–', label: 'No: not supported.' },
} as const;

// Stable footnote numbering by position in compareNotes[].
const noteNumber: Record<string, number> = Object.fromEntries(
  compareNotes.map((n, i) => [n.id, i + 1]),
);
---
<Base title="Structured documents for high-stakes work">
  {/* ─── Section 1 — Hero ─────────────────────────────────────── */}
  <section class="hero" aria-label="Hero">
    <div class="hero-copy">
      <p class="eyebrow">The document format for high-stakes work</p>
      <h1>
        Structured documents
        <br />
        for <span class="primary-ink">work that matters.</span>
      </h1>
      <p class="hero-sub">
        Atto replaces Word for contracts, term sheets, and technical
        documents, bringing collaborative editing, mathematical notation, and
        binding execution into a single structured format.
      </p>
      <div class="hero-ctas">
        <a href="/product" class="btn btn-primary">
          See the product <span aria-hidden="true">→</span>
        </a>
        <a href="/docs" class="btn btn-secondary">Read the spec</a>
      </div>
    </div>

    <div class="hero-demo">
      <AttoDemo filename="services-agreement.atto">
        <article class="atto-doc" slot="rendered">
          <header class="atto-doc-head">
            <p class="atto-doc-kicker">Services Agreement · Effective 2026-04-23</p>
            <h1 class="atto-doc-title">Services Agreement</h1>
          </header>

          <section class="atto-doc-section">
            <h2>Payment Terms</h2>
            <p>
              Client shall pay within <strong>15 days</strong> of invoice.
            </p>
            <p>
              The late fee is <span class="atto-math">L = B × 0.015</span>.
            </p>
          </section>

          <SignatureWidget
            party="Baldwinson Corp."
            signer="Curtis Baldwinson"
            title="CEO"
            order={1}
            totalSigners={2}
          />
        </article>

        <pre class="code-block" slot="source"><code><span class="tok-comment">---</span>
<span class="tok-key">title:</span> <span class="tok-string">Services Agreement</span>
<span class="tok-key">document_type:</span> <span class="tok-string">services_agreement</span>
<span class="tok-key">authoring_mode:</span> <span class="tok-string">hybrid</span>
<span class="tok-key">effective_date:</span> <span class="tok-string">2026-04-23</span>
<span class="tok-comment">---</span>

<span class="tok-heading">## Payment Terms</span>

Client shall pay within <span class="tok-emph">**15 days**</span> of invoice.

The late fee is <span class="tok-math">$L = B \times 0.015$</span>.

<span class="tok-directive">::signature-block</span>
<span class="tok-key">- party:</span> <span class="tok-string">Baldwinson Corp.</span>
<span class="tok-key">  signer:</span> <span class="tok-string">Curtis Baldwinson</span>
<span class="tok-key">  title:</span> <span class="tok-string">CEO</span>
<span class="tok-key">  sign_order:</span> <span class="tok-string">1</span>
<span class="tok-directive">::</span></code></pre>
      </AttoDemo>
    </div>
  </section>

  <hr class="rule" />

  {/* ─── Section 2 — The Problem ──────────────────────────────── */}
  <section class="problem wrap-default section">
    <p class="eyebrow">The gap</p>
    <h2>Word was not built for this.</h2>
    <div class="problem-body">
      <p>
        A signature line in Word is just styled text. A tracked change is a
        cosmetic marker. A due date is a string. There is no semantic model
        under the surface; every meaning lives in the author&rsquo;s head and
        the reviewer&rsquo;s intuition.
      </p>
      <p>
        That works for letters. It breaks for contracts, term sheets, research
        reports, and anything where the document itself is the event. There is
        no canonical source of truth, no clean audit trail, no way to prove the
        file you received is the file that was executed.
      </p>
      <p>
        LaTeX solved notation and nothing else. No collaboration, no review
        workflow, no verification, no path from draft to executed document.
        Teams that need mathematical precision and counterparty screening
        end up stitching together a whole toolchain by hand, and reconciling
        every gap along the way.
      </p>
    </div>
  </section>

  {/* ─── Section 3 — The Hybrid Explainer ─────────────────────────
       Four beats: Markdown → LaTeX → the reconciliation pain → Atto
       as the hybrid. Reader sees each building block in source and
       preview before being shown what happens when they combine. */}
  <section class="section-surface" aria-labelledby="layers-heading">
    <div class="wrap section layers-intro">
      <p class="eyebrow">Architecture</p>
      <h2 id="layers-heading" class="section-heading">
        What Atto is, in three layers.
      </h2>
      <p class="section-lede">
        Atto is a hybrid: <DefineTerm
          term="Markdown"
          partOfSpeech="markup language"
        >A plain-text writing format that uses simple symbols (like <code>**bold**</code> and <code># Heading</code>) to mark structure and emphasis while staying readable as raw text. Created in 2004; widely used for documentation, blogs, and notes.</DefineTerm> for prose, <DefineTerm
          term="LaTeX"
          partOfSpeech="typesetting system"
          pronunciation="lā-tek"
        >A typesetting system designed for mathematical and scientific documents. Authors write formulas as code (e.g. <code>\frac{`{a}{b}`}</code> for a fraction) and the system renders them as properly typeset notation. The standard for academic publishing since the 1980s.</DefineTerm> for notation, and a typed
        directive layer for structure. To see why the hybrid matters, look at
        what each piece does on its own.
      </p>
    </div>

    {/* ─── Beat A — Markdown ───────────────────────────────────── */}
    <div class="layer-beat wrap section">
      <div class="layer-beat-head">
        <p class="beat-num">01</p>
        <h3>
          Markdown: <DefineTerm
            term="prose"
            partOfSpeech="noun"
            pronunciation="prōz"
          >written or spoken language in its ordinary form, without metrical structure: the everyday text of letters, contracts, and reports as opposed to poetry or markup syntax.</DefineTerm>, solved.
        </h3>
      </div>
      <LayerDemo label="Markdown" filename="letter.md">
        <pre slot="source"><code><span class="tok-heading"># Services Agreement</span>

Between <span class="tok-emph">**Atto Technologies Inc.**</span> ("Vendor") and
<span class="tok-emph">**Example Corp.**</span> ("Customer"),
effective <span class="tok-emph">**April 23, 2026**</span>.

<span class="tok-heading">## Scope</span>

- Design consultation
- Proof of concept delivery
- Two rounds of revision

Payment terms are <span class="tok-emph">*net thirty*</span>.</code></pre>

        <article slot="preview" class="atto-doc" style="border: none; padding: 0;">
          <h2 class="atto-doc-title">Services Agreement</h2>
          <p>
            Between <strong>Atto Technologies Inc.</strong> ("Vendor") and
            <strong>Example Corp.</strong> ("Customer"), effective
            <strong>April 23, 2026</strong>.
          </p>
          <h3>Scope</h3>
          <ul>
            <li>Design consultation</li>
            <li>Proof of concept delivery</li>
            <li>Two rounds of revision</li>
          </ul>
          <p>Payment terms are <em>net thirty</em>.</p>
        </article>
      </LayerDemo>
      <p class="layer-caption">
        Markdown carries prose. It&rsquo;s portable, diffable, and human-readable
        in any text editor. But it has no concept of notation, and no concept
        of meaning: a heading is just a heading, a signature line is just a
        bold word.
      </p>
    </div>

    {/* ─── Beat B — LaTeX ──────────────────────────────────────── */}
    <div class="layer-beat wrap section">
      <div class="layer-beat-head">
        <p class="beat-num">02</p>
        <h3>LaTeX: notation, solved.</h3>
      </div>
      <LayerDemo label="LaTeX" filename="valuation.tex">
        <pre slot="source"><code>The present value of future cash flows is:

<span class="tok-directive">\[</span>
  <span class="tok-math">PV = \sum_&#123;t=1&#125;^&#123;T&#125; \frac&#123;C_t&#125;&#123;(1 + r)^t&#125;</span>
<span class="tok-directive">\]</span>

where <span class="tok-math">\(C_t\)</span> is the cash flow in period
<span class="tok-math">\(t\)</span> and <span class="tok-math">\(r\)</span>
is the discount rate.</code></pre>

        <article slot="preview" class="atto-doc" style="border: none; padding: 0;">
          <p>The present value of future cash flows is:</p>
          <span class="atto-math-display">
            <span class="atto-math">PV</span> =
            <span class="atto-sum">
              <span class="lim">T</span>
              <span class="sym">Σ</span>
              <span class="lim"><span class="atto-math">t</span>=1</span>
            </span>
            <span class="atto-frac">
              <span class="num"><span class="atto-math">C<sub>t</sub></span></span>
              <span class="den">(1 + <span class="atto-math">r</span>)<sup><span class="atto-math">t</span></sup></span>
            </span>
          </span>
          <p>
            where <span class="atto-math">C<sub>t</sub></span> is the cash flow
            in period <span class="atto-math">t</span> and
            <span class="atto-math">r</span> is the discount rate.
          </p>
        </article>
      </LayerDemo>
      <p class="layer-caption">
        LaTeX renders notation the way a typesetter would. But the ecosystem
        was built for solo academic authors. No review threads, no signatures,
        no handoff to collaborators who don&rsquo;t also write LaTeX.
      </p>
    </div>

    {/* ─── Beat C — The reconciliation pain ──────────────────────
         Five stages, each a silo of tool alternatives. Stages map
         1-to-1 to the protocol-layer capabilities Atto unifies:
            Drafting    — authoring (Word/Docs/Notion)
            Versioning  — hash-chained history (Git/GitHub) — note
                          this is the only stage where the displaced
                          "tool" (Git) is *external* to the document
                          format itself; in Atto, version integrity
                          is native, not bolted on
            Notation    — math (LaTeX/Overleaf)
            Credit check— verification (TransUnion/Experian/Equifax)
            Signing     — execution (DocuSign/Ironclad)
         Friction breaks (rename the file / type it again / type
         it again / attach and pray) sit between stages. Picking a
         different tool inside a stage doesn't change them, because
         the friction is structural. The labels are deliberately
         consumer-voice, naming what the operator actually does. */}
    <div class="layer-pain wrap section">
      <div class="layer-beat-head">
        <p class="beat-num">03</p>
        <h3>Separate accounts, incompatible formats, one executed PDF that remembers none of it.</h3>
      </div>

      <div class="pain-diagram" role="img" aria-label="Five-stage document workflow with multiple tool alternatives at each stage and broken connections between stages">
        <div class="pain-app pain-app-write">
          <p class="pain-app-role">Drafting</p>
          <ul class="pain-app-tools">
            <li>Microsoft Word</li>
            <li>Google Docs</li>
            <li>Notion</li>
          </ul>
          <p class="pain-app-file"><code>term-sheet.docx</code></p>
        </div>
        <div class="pain-break" aria-hidden="true">
          <span class="pain-break-mark">
            <X size={14} stroke-width={2.5} aria-hidden="true" focusable="false" />
          </span>
          <span class="pain-break-label">rename the file</span>
        </div>
        <div class="pain-app pain-app-version">
          <p class="pain-app-role">Versioning</p>
          <ul class="pain-app-tools">
            <li>Git</li>
            <li>GitHub</li>
          </ul>
          <p class="pain-app-file"><code>.git/</code></p>
        </div>
        <div class="pain-break" aria-hidden="true">
          <span class="pain-break-mark">
            <X size={14} stroke-width={2.5} aria-hidden="true" focusable="false" />
          </span>
          <span class="pain-break-label">type it again</span>
        </div>
        <div class="pain-app pain-app-math">
          <p class="pain-app-role">Notation</p>
          <ul class="pain-app-tools">
            <li>LaTeX</li>
            <li>Overleaf</li>
          </ul>
          <p class="pain-app-file"><code>valuation.tex</code></p>
        </div>
        <div class="pain-break" aria-hidden="true">
          <span class="pain-break-mark">
            <X size={14} stroke-width={2.5} aria-hidden="true" focusable="false" />
          </span>
          <span class="pain-break-label">type it again</span>
        </div>
        <div class="pain-app pain-app-verify">
          <p class="pain-app-role">Credit check</p>
          <ul class="pain-app-tools">
            <li>TransUnion</li>
            <li>Experian</li>
            <li>Equifax</li>
          </ul>
          <p class="pain-app-file"><code>report.pdf</code></p>
        </div>
        <div class="pain-break" aria-hidden="true">
          <span class="pain-break-mark">
            <X size={14} stroke-width={2.5} aria-hidden="true" focusable="false" />
          </span>
          <span class="pain-break-label">attach and pray</span>
        </div>
        <div class="pain-app pain-app-sign">
          <p class="pain-app-role">Signing</p>
          <ul class="pain-app-tools">
            <li>DocuSign</li>
            <li>Ironclad</li>
          </ul>
          <p class="pain-app-file"><code>executed.pdf</code></p>
        </div>
      </div>

      <p class="layer-caption pain-caption">
        For leases, financing applications, and regulated agreements, every
        team assembles the same sprawling combination of accounts, platforms,
        and exports. The products change by industry and firm; the friction
        doesn&rsquo;t. Every step rekeys data the last step already had. Every
        handoff produces a new file in a new format. And the executed PDF at
        the end (the one that gets filed, stored, and treated as the record of
        truth) has no structural relationship to the draft that was reviewed,
        the screening that approved it, or the math that priced it. It&rsquo;s
        a photograph of a process that no longer exists anywhere.
      </p>
    </div>

    {/* ─── Beat D — The hybrid ─────────────────────────────────── */}
    <div class="layer-beat wrap section layer-beat-hybrid">
      <div class="layer-beat-head">
        <p class="beat-num">04</p>
        <h3>Atto: one source, three layers, one protocol.</h3>
      </div>
      <LayerDemo label="Atto" filename="services-agreement.atto">
        <pre slot="source"><code><span class="tok-heading"># Services Agreement</span>

Between <span class="tok-emph">**Atto Technologies Inc.**</span> ("Vendor") and
<span class="tok-emph">**Example Corp.**</span>, effective
<span class="tok-emph">**April 23, 2026**</span>.

<span class="tok-heading">## Compensation</span>

Vendor will be paid in quarterly installments, with net present value:

<span class="tok-math">$$
PV = \sum_&#123;t=1&#125;^&#123;T&#125; \frac&#123;C_t&#125;&#123;(1 + r)^t&#125;
$$</span>

<span class="tok-directive">::signature-block</span>
<span class="tok-key">  party:</span> <span class="tok-string">Atto Technologies Inc.</span>
<span class="tok-key">  signer:</span> <span class="tok-string">Curtis Baldwinson</span>
<span class="tok-key">  title:</span> <span class="tok-string">CEO</span>
<span class="tok-key">  sign_order:</span> <span class="tok-string">1</span>
<span class="tok-directive">::</span></code></pre>

        <article slot="preview" class="atto-doc" style="border: none; padding: 0;">
          <h2 class="atto-doc-title">Services Agreement</h2>
          <p>
            Between <strong>Atto Technologies Inc.</strong> ("Vendor") and
            <strong>Example Corp.</strong>, effective
            <strong>April 23, 2026</strong>.
          </p>
          <h3>Compensation</h3>
          <p>Vendor will be paid in quarterly installments, with net present value:</p>
          <span class="atto-math-display">
            <span class="atto-math">PV</span> =
            <span class="atto-sum">
              <span class="lim">T</span>
              <span class="sym">Σ</span>
              <span class="lim"><span class="atto-math">t</span>=1</span>
            </span>
            <span class="atto-frac">
              <span class="num"><span class="atto-math">C<sub>t</sub></span></span>
              <span class="den">(1 + <span class="atto-math">r</span>)<sup><span class="atto-math">t</span></sup></span>
            </span>
          </span>
          <SignatureWidget
            party="Atto Technologies Inc."
            signer="Curtis Baldwinson"
            title="CEO"
            order={1}
            totalSigners={2}
          />
        </article>
      </LayerDemo>
      <p class="layer-caption">
        One source file: Markdown prose, LaTeX notation, and typed directives,
        all parsed to a single deterministic tree. The protocol layer makes
        that tree do work: hash-chained revision history, signatures locked
        to the content hash, executable math frozen at signing, and directives
        like <code>:::credit-check</code> that gate execution on real-world
        preconditions. All of it. In one file.
      </p>
    </div>
  </section>

  {/* ─── Section 4 — Live Collaboration ───────────────────────── */}
  <section class="collab wrap section">
    <div class="collab-copy">
      <p class="eyebrow">Collaboration: always in sync</p>
      <h2 class="section-heading">Real-time. Without the chaos.</h2>
      <p>
        Every section of an Atto document syncs the moment you touch it.
        Two authors can edit simultaneously with no locking, no
        &ldquo;someone else is editing this,&rdquo; and no overwritten work.
        A co-signer can execute their signature while a clause is still
        being revised on the other side of the document.
      </p>
      <p>
        Drop your connection mid-edit. Come back. Everything is exactly
        where you left it.
      </p>
    </div>
    <figure class="collab-diagram" aria-label="Atto transport architecture">
      <pre class="code-block"><code>Browser Editor
    │
    ▼  MQTT / QUIC
Atto Relay Broker
    │
    ▼
Document State Service ──── Patch Log
    │
    ▼
Baldwinson Protocol Layer</code></pre>
    </figure>
  </section>

  {/* ─── Section 5 — Document Lifecycle ───────────────────────── */}
  <section class="lifecycle wrap section">
    <p class="eyebrow">Lifecycle</p>
    <h2 class="section-heading">
      Draft, review, sign, freeze, execute. All in one format.
    </h2>
    <p class="section-lede">
      Every stage is a typed transition, captured in the document and the
      patch log. There is no external state.
    </p>
    <ol class="stages" role="list">
      {lifecycle.map((stage, i) => (
        <li class="stage" data-active={i === 0}>
          <span class="stage-dot" aria-hidden="true"></span>
          <span class="stage-name">{stage.name}</span>
          <span class="stage-desc">{stage.desc}</span>
        </li>
      ))}
    </ol>
  </section>

  {/* ─── Section 6 — Comparison Matrix ─────────────────────────
       10 capability rows × 6 tools. Atto is the only ✓-across-all
       column. Two rows (executable math frozen at signing, native
       :::credit-check) are unique to Atto and visually highlighted.
       ⚠ cells link down to footnotes that explain the partial. */}
  <section class="compare wrap section" aria-labelledby="compare-heading">
    <p class="eyebrow">Comparison</p>
    <h2 id="compare-heading" class="section-heading">
      What no other tool does.
    </h2>
    <p class="section-lede">
      Atto is the only tool that does all of this. Here&rsquo;s how the six
      it displaces compare across ten capabilities.
    </p>

    <ul class="cmp-legend" aria-label="Symbol legend">
      <li>
        <span class="cmp-glyph cmp-y" aria-hidden="true">✓</span>
        <span>Native: built into the core product.</span>
      </li>
      <li>
        <span class="cmp-glyph cmp-p" aria-hidden="true">⚠</span>
        <span>Partial: appended externally, lacks structural integrity, or requires another tool.</span>
      </li>
      <li>
        <span class="cmp-glyph cmp-n" aria-hidden="true">–</span>
        <span>Not supported.</span>
      </li>
    </ul>

    <div class="compare-wrap" role="region" aria-label="Capability matrix" tabindex="0">
      <table class="cmp-table">
        <thead>
          <tr>
            <th scope="col" class="cmp-feature-head">Capability</th>
            {compareTools.map((tool, i) => (
              <th scope="col" class={`cmp-tool-head${i === 0 ? ' cmp-tool-atto' : ''}`}>
                {tool}
              </th>
            ))}
          </tr>
        </thead>
        <tbody>
          {compareRows.map((row) => (
            <tr class={row.uniqueAtto ? 'cmp-row-unique' : ''}>
              <th scope="row" class="cmp-feature">{row.feature}</th>
              {row.cells.map((cell, i) => {
                const sym = compareSymbols[cell.v];
                const fnNum = cell.fn ? noteNumber[cell.fn] : undefined;
                return (
                  <td class={`cmp-cell cmp-${cell.v}${i === 0 ? ' cmp-cell-atto' : ''}`}>
                    <span class="cmp-glyph" aria-hidden="true">{sym.glyph}</span>
                    <span class="cmp-sr">{sym.label}</span>
                    {cell.fn && fnNum !== undefined && (
                      <sup class="cmp-fn-mark">
                        <a href={`#${cell.fn}`} aria-label={`See footnote ${fnNum}`}>
                          {fnNum}
                        </a>
                      </sup>
                    )}
                  </td>
                );
              })}
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <ol class="cmp-notes" aria-label="Footnotes for partial-support ratings">
      {compareNotes.map((note) => (
        <li id={note.id} class="cmp-note">
          <span class="cmp-note-num" aria-hidden="true">{noteNumber[note.id]}</span>
          <span class="cmp-note-text">{note.text}</span>
        </li>
      ))}
    </ol>
  </section>

  {/* ─── Section 7 — CTA Banner ───────────────────────────────── */}
  <section class="cta-banner section-dark" aria-labelledby="cta-heading">
    <div class="wrap-default cta-inner">
      <h2 id="cta-heading">The document format for serious work.</h2>
      <a href="/waitlist" class="btn btn-on-dark">
        Join the waitlist <span aria-hidden="true">→</span>
      </a>
    </div>
  </section>
</Base>

<style>
  /* ─── Hero ──────────────────────────────────────────────────── */
  .hero {
    display: grid;
    /* `1fr 1fr` is implicitly `minmax(auto, 1fr) minmax(auto, 1fr)` —
       the auto min-size lets a column grow past 50% if its content's
       intrinsic min-size demands it. The hero AttoDemo's source <pre>
       has white-space: pre (no line breaks) so its min-content equals
       its longest line, which pushes the right column wider when the
       Source tab is active. That visibly shifts the right-anchored
       filename in the demo head between tabs. `minmax(0, 1fr)` pins
       both columns to exactly 50%; the pre stays contained by its
       own overflow-x: auto. */
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    /* 64px gap (var(--space-16)) felt oversized on the now-wider
       1440px frame and stole horizontal room from the AttoDemo
       column. 40px (var(--space-10)) keeps the two columns visually
       distinct while giving the demo card meaningful extra width to
       breathe — net gain ~12px per column on large desktops. The
       single-column mobile layout below uses --space-12 (48px) for
       its vertical stack, where gap cost is cheaper. */
    gap: var(--space-10);
    align-items: start;
    min-height: 90vh;
    padding: var(--space-24) var(--space-8);
    max-width: var(--content-wide);
    margin: 0 auto;
  }

  .hero-copy h1 {
    font-family: var(--font-display);
    font-weight: 800;
    /* The shared --text-hero scale (clamp(3rem, 0.5rem + 7vw, 8rem))
       assumes near-full-width content and reaches 128px on large
       desktops, which overflowed the two-column hero. Going the
       other way (≤80px to fit "Structured documents" on one line in
       a ~660px column) traded too much hero impact. Compromise:
       cap at 96px and embrace the wrap — at large desktops the
       heading reads as three lines:
         Structured
         documents
         for work that matters.
       which is a deliberate stacked-typography pattern, not an
       overflow. `overflow-wrap: break-word` below stays as the
       safety net for any truly oversized word. */
    font-size: clamp(2.75rem, 1rem + 5vw, 6rem);
    letter-spacing: -0.02em;
    line-height: 0.95;
    margin-block: var(--space-6);
    /* Safety net: if a viewport/column ratio still leaves a single
       word too wide to fit, break it at the column edge instead of
       letting it bleed into the demo column. */
    overflow-wrap: break-word;
  }

  .primary-ink { color: var(--color-primary); }

  .hero-sub {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    max-width: 46ch;
    margin-bottom: var(--space-8);
  }

  .hero-demo {
    position: relative;
    /* Same containment pattern as `.docs-content` on the docs page:
       `min-width: 0` lets this grid item shrink below the intrinsic
       min-size of its children. Without it, on narrow mobile viewports
       (e.g. 390px iPhone 12 Pro) the AttoDemo's source <pre> longest
       line forces this column wider than the viewport, pushing the
       whole card past the page's left/right padding. With `min-width:
       0`, the column collapses to the available width and the pre
       scrolls internally via its own overflow-x: auto. */
    min-width: 0;
  }

  /* Symmetric containment for the copy column so a single ultra-long
     word (URL, code token) can't blow out the layout either. Text in
     this column wraps normally so the min-content is small in
     practice — this is a defensive belt-and-suspenders rule. */
  .hero-copy {
    min-width: 0;
  }

  @media (max-width: 1024px) {
    .hero {
      grid-template-columns: 1fr;
      gap: var(--space-12);
      min-height: auto;
      padding: var(--space-16) var(--space-6);
    }
  }

  /* ─── Problem ───────────────────────────────────────────────── */
  .problem h2 {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: var(--text-2xl);
    margin-block: var(--space-4) var(--space-10);
    max-width: 20ch;
  }

  .problem-body {
    display: grid;
    gap: var(--space-6);
    max-width: 68ch;
  }

  .problem-body p {
    font-size: var(--text-base);
    color: var(--color-text);
  }

  /* ─── Hybrid Explainer (four beats) ─────────────────────────
     Each .layer-beat is a self-contained story unit: header with
     beat number + inline h3, the LayerDemo component, and a caption
     paragraph below. Beats are padded vertically so the transitions
     feel paced, not crammed. */
  .layers-intro {
    padding-bottom: var(--space-8);
  }

  .layer-beat,
  .layer-pain {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    padding-block: var(--space-12);
    border-top: 1px solid var(--color-border);
  }

  .layer-beat-head {
    display: flex;
    align-items: baseline;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .beat-num {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.12em;
    color: var(--color-text-faint);
    margin: 0;
  }

  .layer-beat-head h3 {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: var(--text-2xl);
    margin: 0;
  }

  .layer-caption {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    max-width: 64ch;
  }

  /* Inline <code> inside layer captions — Beat D mentions
     :::credit-check by name and that should read as code, not as
     a muted word. Matches the .atto-doc code recipe. */
  .layer-caption code {
    font-family: var(--font-mono);
    font-size: 0.92em;
    padding: 0.05em 0.3em;
    background: var(--color-code-bg);
    border: 1px solid var(--color-border);
    color: var(--color-text);
  }

  /* The hybrid beat gets a subtle left-edge accent so it reads as the
     resolution of the preceding pain beat, not just another example. */
  .layer-beat-hybrid {
    position: relative;
  }

  .layer-beat-hybrid::before {
    content: '';
    position: absolute;
    inset-block: var(--space-8);
    left: calc(var(--space-4) * -1);
    width: 2px;
    background: var(--color-primary);
  }

  @media (max-width: 768px) {
    .layer-beat-hybrid::before {
      display: none;
    }
  }

  /* ─── Pain diagram (Beat C) ──────────────────────────────────
     Five "app" cards with broken-link indicators between them,
     visualizing the draft → version → typeset → screen → sign
     workflow. Mobile (≤900px) collapses to a single column
     so each app and break stacks vertically.

     Grid columns expand to 9 (5 cards + 4 break gutters) — at
     content width the row gets dense; if cards feel cramped,
     reduce .pain-app padding before changing the grid template
     (the column count needs to stay at 9 to preserve the
     card-break-card-break rhythm). */
  .pain-diagram {
    display: grid;
    grid-template-columns: 1fr auto 1fr auto 1fr auto 1fr auto 1fr;
    align-items: stretch;
    gap: var(--space-3);
    padding: var(--space-6);
    border: 1px solid var(--color-border);
    background: var(--color-bg);
  }

  .pain-app {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: var(--space-5) var(--space-5);
    border: 1px solid var(--color-border);
    background: var(--color-surface);
    min-width: 0;
  }

  .pain-app-role {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin: 0;
  }

  /* Tool alternatives list inside each stage card. Replaces the
     previous .pain-app-name (single name per card) — each stage now
     enumerates the 1-3 displaced tools that teams pick from at that
     step. Same display-font weight as the old .pain-app-name so the
     visual prominence carries through; tight line-height keeps the
     stack readable inside the card without inflating the diagram's
     vertical footprint. */
  .pain-app-tools {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .pain-app-tools li {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--text-base);
    color: var(--color-text);
    line-height: 1.2;
  }

  .pain-app-file {
    /* `margin-top: auto` pushes the file-label row to the bottom of
       the card. With cards now containing 1-3 tool names, content
       heights differ; without this rule the file labels would sit
       directly under the tools list at varying vertical positions
       across cards. Auto-margin lets shorter cards absorb the
       leftover space above the file label so file labels align
       horizontally across the diagram. */
    margin: auto 0 0;
  }

  .pain-app-file code {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    padding: 0.1em 0.35em;
    background: var(--color-code-bg);
    border: 1px solid var(--color-border);
    color: var(--color-text-muted);
  }

  .pain-break {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    min-width: 64px;
  }

  /* Square wrapper around the Lucide X icon. The icon itself inherits color
     via `currentColor`, so setting `color` here drives both stroke and
     border tone together. */
  .pain-break-mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    color: #B5651D;
    background: var(--color-bg);
    border: 1px solid #B5651D;
  }

  .pain-break-label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
    text-align: center;
    text-wrap: balance;
  }

  .pain-caption {
    max-width: 64ch;
  }

  @media (max-width: 900px) {
    .pain-diagram {
      grid-template-columns: 1fr;
    }

    .pain-break {
      flex-direction: row;
      gap: var(--space-3);
      min-width: 0;
      padding-block: var(--space-2);
    }
  }

  /* ─── Live Collaboration ────────────────────────────────────── */
  .collab {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-16);
    align-items: center;
  }

  .collab-copy {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .collab-copy p {
    font-size: var(--text-base);
    max-width: 48ch;
  }

  .collab-diagram .code-block {
    font-size: var(--text-sm);
    line-height: 1.8;
  }

  @media (max-width: 900px) {
    .collab {
      grid-template-columns: 1fr;
      gap: var(--space-10);
    }
  }

  /* ─── Lifecycle ─────────────────────────────────────────────── */
  .stages {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 0;
    margin-top: var(--space-12);
    position: relative;
  }

  .stages::before {
    content: '';
    position: absolute;
    top: 10px;
    left: 10%;
    right: 10%;
    height: 1px;
    background: var(--color-border);
    z-index: 0;
  }

  .stage {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-2);
    padding-right: var(--space-4);
    position: relative;
    z-index: 1;
  }

  .stage-dot {
    width: 11px;
    height: 11px;
    background: var(--color-border);
    border: 2px solid var(--color-bg);
    box-sizing: content-box;
    display: inline-block;
  }

  .stage[data-active="true"] .stage-dot {
    background: var(--color-primary);
  }

  .stage[data-active="true"] .stage-name {
    color: var(--color-primary);
  }

  .stage-name {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: var(--text-lg);
    color: var(--color-text);
    line-height: 1;
    margin-top: var(--space-2);
  }

  .stage-desc {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    max-width: 18ch;
  }

  @media (max-width: 768px) {
    .stages {
      grid-template-columns: 1fr;
      gap: var(--space-6);
    }

    .stages::before {
      top: 0;
      left: 5px;
      right: auto;
      bottom: 0;
      width: 1px;
      height: auto;
    }

    .stage {
      padding-left: var(--space-6);
      padding-right: 0;
    }

    .stage-dot {
      position: absolute;
      left: 0;
      top: 4px;
    }
  }

  /* ─── Comparison Matrix ─────────────────────────────────────
     10 capability rows × 6 tool columns. Visual hierarchy:
       - Legend at the top (✓ ⚠ – key)
       - Atto column tinted with primary so the eye lands on the
         "always ✓" stripe.
       - Two unique-to-Atto rows tinted across all cells so the
         reader can find the no-other-tool-does-this rows at a
         glance.
       - First column (Capability label) is position: sticky
         during horizontal scroll on narrow viewports — without
         it the row headers disappear off-screen as you scroll.
       - Footnotes are an <ol> below the table; each ⚠ cell links
         down via its sup numeral, and the targeted note flashes
         a primary tint so the reader knows where they landed. */

  /* Lede paragraph between heading and legend */
  .compare .section-lede {
    margin-top: var(--space-4);
    margin-bottom: 0;
  }

  /* Legend — the ✓ ⚠ – key. Inline, wraps on narrow widths. */
  .cmp-legend {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3) var(--space-6);
    margin: var(--space-8) 0 var(--space-6);
    padding: 0;
    list-style: none;
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .cmp-legend li {
    display: flex;
    align-items: baseline;
    gap: var(--space-2);
  }

  /* Shared glyph (✓ ⚠ –) shape — used in both legend and cells.
     min-width keeps cells aligned vertically even with the narrow
     '–' versus the wider '✓' / '⚠'. */
  .cmp-glyph {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 1.2em;
    font-family: var(--font-body);
    font-weight: 700;
    line-height: 1;
  }

  .cmp-y { color: var(--color-primary); }
  /* Amber for partial — same hue as the pain-break X icons so the
     two "broken / patchy" signals on the page share a visual code. */
  .cmp-p { color: #B5651D; }
  .cmp-n { color: var(--color-text-faint); }

  /* Wrapper carries the border + horizontal scroll. tabindex=0 (set
     in the JSX) makes the region keyboard-focusable so users on
     keyboard-only navigation can scroll the matrix horizontally. */
  .compare-wrap {
    border: 1px solid var(--color-border);
    overflow-x: auto;
    margin-top: 0;
  }

  .compare-wrap:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }

  .cmp-table {
    border-collapse: collapse;
    width: 100%;
    font-size: var(--text-sm);
    background: var(--color-bg);
  }

  /* Column headers (top row) */
  .cmp-table thead th {
    padding: var(--space-4) var(--space-5);
    background: var(--color-surface);
    border-bottom: 1px solid var(--color-border);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text);
    white-space: nowrap;
    vertical-align: middle;
  }

  .cmp-feature-head {
    text-align: left;
    /* Sticky during horizontal scroll — keep "Capability" anchored
       at the left edge so the column meaning stays visible. */
    position: sticky;
    left: 0;
    z-index: 2;
    background: var(--color-surface);
    border-right: 1px solid var(--color-border);
    min-width: 220px;
  }

  .cmp-tool-head {
    text-align: center;
    min-width: 110px;
  }

  /* The Atto column gets a primary-tinted header to anchor the
     "this is the one that does it all" stripe. */
  .cmp-tool-atto {
    color: var(--color-primary);
    background: color-mix(in oklch, var(--color-primary) 10%, var(--color-surface));
  }

  /* Body row labels (left column) */
  .cmp-feature {
    padding: var(--space-4) var(--space-5);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--text-sm);
    color: var(--color-text);
    text-align: left;
    vertical-align: middle;
    border-bottom: 1px solid var(--color-border);
    border-right: 1px solid var(--color-border);
    /* Stick at the left edge during horizontal scroll. Lower z than
       the thead so the column-header sticky still wins at the
       intersection. */
    position: sticky;
    left: 0;
    z-index: 1;
    background: var(--color-bg);
    min-width: 220px;
  }

  /* Body cells (the ✓/⚠/– grid) */
  .cmp-cell {
    padding: var(--space-4) var(--space-5);
    border-bottom: 1px solid var(--color-border);
    text-align: center;
    vertical-align: middle;
    white-space: nowrap;
    position: relative;
  }

  /* Atto column body — same primary tint as the header, lighter. */
  .cmp-cell-atto {
    background: color-mix(in oklch, var(--color-primary) 6%, transparent);
  }

  /* Unique-to-Atto rows previously had a stronger Atto-cell tint to
     mark them visually, but the darker shade on just two rows of
     the column read as inconsistent. The Atto column now stays at
     a uniform 6% tint top-to-bottom; the strategic claim ("only
     Atto has ✓ on these rows") is left to the row content itself —
     readers can scan across the – – – – – pattern in the
     non-Atto cells of those rows. The .cmp-row-unique class is
     retained on the <tr> for future use (e.g. an inline "Only Atto"
     annotation) but currently has no visual treatment attached. */

  /* Last-row border cleanup */
  .cmp-table tbody tr:last-child .cmp-feature,
  .cmp-table tbody tr:last-child .cmp-cell {
    border-bottom: none;
  }

  /* Footnote sup numerals inside ⚠ cells. Mono font + dotted under
     to read as "click for explanation". */
  .cmp-fn-mark {
    margin-left: 0.2em;
    font-family: var(--font-mono);
    font-size: 0.7em;
    font-weight: 600;
    line-height: 1;
  }

  .cmp-fn-mark a {
    color: var(--color-text-muted);
    text-decoration: none;
    border-bottom: 1px dotted currentColor;
  }

  .cmp-fn-mark a:hover,
  .cmp-fn-mark a:focus-visible {
    color: var(--color-primary);
    border-bottom-color: var(--color-primary);
  }

  /* Screen-reader-only — used to expose "Yes / Partial / No" text
     to AT alongside the visual ✓/⚠/– glyph (which is aria-hidden). */
  .cmp-sr {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* Footnotes list under the table. The numbering comes from the
     `noteNumber` map computed in the frontmatter (stable index based
     on compareNotes[] order); no CSS counter needed. */
  .cmp-notes {
    margin: var(--space-8) 0 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: var(--space-3);
    max-width: 70ch;
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .cmp-note {
    display: grid;
    grid-template-columns: 1.6em 1fr;
    gap: var(--space-2);
    line-height: 1.5;
    padding: var(--space-2) var(--space-2);
    /* Account for fixed nav when scrolling to a footnote target. */
    scroll-margin-top: var(--space-12);
    text-wrap: pretty;
  }

  /* Brief highlight when the user follows a sup link to a footnote
     so they can find their landing spot. :target is supported in
     every modern browser and resets when the user clicks elsewhere. */
  .cmp-note:target {
    background: color-mix(in oklch, var(--color-primary) 8%, transparent);
    border-radius: 2px;
  }

  .cmp-note-num {
    font-family: var(--font-mono);
    font-weight: 700;
    color: var(--color-primary);
    text-align: right;
  }

  /* Mobile tightening — smaller padding, narrower minimums. The
     horizontal scroll still kicks in below ~700px; sticky first
     column means readers can scroll the value cells without
     losing the row label. */
  @media (max-width: 768px) {
    .cmp-feature-head,
    .cmp-feature {
      min-width: 180px;
