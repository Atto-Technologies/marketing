---
import Base from '../layouts/Base.astro';
import { X } from '@lucide/astro';
import AttoDemo from '../components/AttoDemo.astro';
import LayerDemo from '../components/LayerDemo.astro';
import SignatureWidget from '../components/SignatureWidget.astro';
import DefineTerm from '../components/DefineTerm.astro';

const lifecycle = [
  { name: 'Draft', desc: 'Authors compose and revise.' },
  { name: 'Review', desc: 'Comments anchor to the AST.' },
  { name: 'Sign', desc: 'Parties countersign in order.' },
  { name: 'Freeze', desc: 'Content becomes immutable.' },
  { name: 'Execute', desc: 'Protocol events fire on effect.' },
];

const rows = [
  {
    dim: 'Document format',
    trad: 'Proprietary binary / XML',
    atto: 'Open hybrid syntax (Markdown + LaTeX + directives)',
  },
  {
    dim: 'Collaboration',
    trad: 'File sharing, tracked changes',
    atto: 'Real-time CRDT sync over MQTT',
  },
  {
    dim: 'Version control',
    trad: 'Manual saves, no canonical diff',
    atto: 'Deterministic serialization, git-compatible',
  },
  {
    dim: 'Signatures',
    trad: 'Styled text or external tool',
    atto: 'Typed ::signature-block nodes, protocol-native',
  },
  {
    dim: 'Math notation',
    trad: 'Insert object / external',
    atto: 'Native inline and display LaTeX',
  },
  {
    dim: 'Lifecycle awareness',
    trad: 'None',
    atto: 'Draft → Review → Sign → Freeze → Execute',
  },
];
---
<Base title="Structured documents for high-stakes work">
  {/* ─── Section 1 — Hero ─────────────────────────────────────── */}
  <section class="hero" aria-label="Hero">
    <div class="hero-copy">
      <p class="eyebrow">The document format for high-stakes work</p>
      <h1>
        Structured documents
        <br />
        for <span class="primary-ink">work that matters.</span>
      </h1>
      <p class="hero-sub">
        Atto replaces Word for contracts, term sheets, and technical
        documents—bringing collaborative editing, mathematical notation, and
        binding execution into a single structured format.
      </p>
      <div class="hero-ctas">
        <a href="/product" class="btn btn-primary">
          See the product <span aria-hidden="true">→</span>
        </a>
        <a href="/docs" class="btn btn-secondary">Read the spec</a>
      </div>
    </div>

    <div class="hero-demo">
      <AttoDemo filename="services-agreement.atto">
        <article class="atto-doc" slot="rendered">
          <header class="atto-doc-head">
            <p class="atto-doc-kicker">Services Agreement · Effective 2026-04-23</p>
            <h1 class="atto-doc-title">Services Agreement</h1>
          </header>

          <section class="atto-doc-section">
            <h2>Payment Terms</h2>
            <p>
              Client shall pay within <strong>15 days</strong> of invoice.
            </p>
            <p>
              The late fee is <span class="atto-math">L = B × 0.015</span>.
            </p>
          </section>

          <SignatureWidget
            party="Baldwinson Corp."
            signer="Curtis Baldwinson"
            title="CEO"
            order={1}
            totalSigners={2}
          />
        </article>

        <pre class="code-block" slot="source"><code><span class="tok-comment">---</span>
<span class="tok-key">title:</span> <span class="tok-string">Services Agreement</span>
<span class="tok-key">document_type:</span> <span class="tok-string">services_agreement</span>
<span class="tok-key">authoring_mode:</span> <span class="tok-string">hybrid</span>
<span class="tok-key">effective_date:</span> <span class="tok-string">2026-04-23</span>
<span class="tok-comment">---</span>

<span class="tok-heading">## Payment Terms</span>

Client shall pay within <span class="tok-emph">**15 days**</span> of invoice.

The late fee is <span class="tok-math">$L = B \times 0.015$</span>.

<span class="tok-directive">::signature-block</span>
<span class="tok-key">- party:</span> <span class="tok-string">Baldwinson Corp.</span>
<span class="tok-key">  signer:</span> <span class="tok-string">Curtis Baldwinson</span>
<span class="tok-key">  title:</span> <span class="tok-string">CEO</span>
<span class="tok-key">  sign_order:</span> <span class="tok-string">1</span>
<span class="tok-directive">::</span></code></pre>
      </AttoDemo>
    </div>
  </section>

  <hr class="rule" />

  {/* ─── Section 2 — The Problem ──────────────────────────────── */}
  <section class="problem wrap-default section">
    <p class="eyebrow">The gap</p>
    <h2>Word was not built for this.</h2>
    <div class="problem-body">
      <p>
        A signature line in Word is just styled text. A tracked change is a
        cosmetic marker. A due date is a string. There is no semantic model
        under the surface — every meaning lives in the author&rsquo;s head and
        the reviewer&rsquo;s intuition.
      </p>
      <p>
        That works for letters. It breaks for contracts, term sheets, research
        reports, and anything where the document itself is the event. There is
        no canonical source of truth, no clean audit trail, no way to prove the
        file you received is the file that was executed.
      </p>
      <p>
        LaTeX solved notation and nothing else. No collaboration, no review
        workflow, no path from draft to executed document. Teams that need
        mathematical precision end up maintaining two systems — and a third
        to reconcile them.
      </p>
    </div>
  </section>

  {/* ─── Section 3 — The Hybrid Explainer ─────────────────────────
       Four beats: Markdown → LaTeX → the reconciliation pain → Atto
       as the hybrid. Reader sees each building block in source and
       preview before being shown what happens when they combine. */}
  <section class="section-surface" aria-labelledby="layers-heading">
    <div class="wrap section layers-intro">
      <p class="eyebrow">Architecture</p>
      <h2 id="layers-heading" class="section-heading">
        What Atto is, in three layers.
      </h2>
      <p class="section-lede">
        Atto is a hybrid: <DefineTerm
          term="Markdown"
          partOfSpeech="markup language"
        >A plain-text writing format that uses simple symbols — like <code>**bold**</code> and <code># Heading</code> — to mark structure and emphasis while staying readable as raw text. Created in 2004; widely used for documentation, blogs, and notes.</DefineTerm> for prose, <DefineTerm
          term="LaTeX"
          partOfSpeech="typesetting system"
          pronunciation="lā-tek"
        >A typesetting system designed for mathematical and scientific documents. Authors write formulas as code (e.g. <code>\frac{`{a}{b}`}</code> for a fraction) and the system renders them as properly typeset notation. The standard for academic publishing since the 1980s.</DefineTerm> for notation, and a typed
        directive layer for structure. To see why the hybrid matters, look at
        what each piece does on its own.
      </p>
    </div>

    {/* ─── Beat A — Markdown ───────────────────────────────────── */}
    <div class="layer-beat wrap section">
      <div class="layer-beat-head">
        <p class="beat-num">01</p>
        <h3>
          Markdown: <DefineTerm
            term="prose"
            partOfSpeech="noun"
            pronunciation="prōz"
          >written or spoken language in its ordinary form, without metrical structure — the everyday text of letters, contracts, and reports as opposed to poetry or markup syntax.</DefineTerm>, solved.
        </h3>
      </div>
      <LayerDemo label="Markdown" filename="letter.md">
        <pre slot="source"><code><span class="tok-heading"># Services Agreement</span>

Between <span class="tok-emph">**Atto Technologies Inc.**</span> ("Vendor") and
<span class="tok-emph">**Example Corp.**</span> ("Customer"),
effective <span class="tok-emph">**April 23, 2026**</span>.

<span class="tok-heading">## Scope</span>

- Design consultation
- Proof of concept delivery
- Two rounds of revision

Payment terms are <span class="tok-emph">*net thirty*</span>.</code></pre>

        <article slot="preview" class="atto-doc" style="border: none; padding: 0;">
          <h2 class="atto-doc-title">Services Agreement</h2>
          <p>
            Between <strong>Atto Technologies Inc.</strong> ("Vendor") and
            <strong>Example Corp.</strong> ("Customer"), effective
            <strong>April 23, 2026</strong>.
          </p>
          <h3>Scope</h3>
          <ul>
            <li>Design consultation</li>
            <li>Proof of concept delivery</li>
            <li>Two rounds of revision</li>
          </ul>
          <p>Payment terms are <em>net thirty</em>.</p>
        </article>
      </LayerDemo>
      <p class="layer-caption">
        Markdown carries prose. It&rsquo;s portable, diffable, and human-readable
        in any text editor. But it has no concept of notation, and no concept
        of meaning — a heading is just a heading, a signature line is just a
        bold word.
      </p>
    </div>

    {/* ─── Beat B — LaTeX ──────────────────────────────────────── */}
    <div class="layer-beat wrap section">
      <div class="layer-beat-head">
        <p class="beat-num">02</p>
        <h3>LaTeX: notation, solved.</h3>
      </div>
      <LayerDemo label="LaTeX" filename="valuation.tex">
        <pre slot="source"><code>The present value of future cash flows is:

<span class="tok-directive">\[</span>
  <span class="tok-math">PV = \sum_&#123;t=1&#125;^&#123;T&#125; \frac&#123;C_t&#125;&#123;(1 + r)^t&#125;</span>
<span class="tok-directive">\]</span>

where <span class="tok-math">\(C_t\)</span> is the cash flow in period
<span class="tok-math">\(t\)</span> and <span class="tok-math">\(r\)</span>
is the discount rate.</code></pre>

        <article slot="preview" class="atto-doc" style="border: none; padding: 0;">
          <p>The present value of future cash flows is:</p>
          <span class="atto-math-display">
            <span class="atto-math">PV</span> =
            <span class="atto-sum">
              <span class="lim">T</span>
              <span class="sym">Σ</span>
              <span class="lim"><span class="atto-math">t</span>=1</span>
            </span>
            <span class="atto-frac">
              <span class="num"><span class="atto-math">C<sub>t</sub></span></span>
              <span class="den">(1 + <span class="atto-math">r</span>)<sup><span class="atto-math">t</span></sup></span>
            </span>
          </span>
          <p>
            where <span class="atto-math">C<sub>t</sub></span> is the cash flow
            in period <span class="atto-math">t</span> and
            <span class="atto-math">r</span> is the discount rate.
          </p>
        </article>
      </LayerDemo>
      <p class="layer-caption">
        LaTeX renders notation the way a typesetter would. But the ecosystem
        was built for solo academic authors. No review threads, no signatures,
        no handoff to collaborators who don&rsquo;t also write LaTeX.
      </p>
    </div>

    {/* ─── Beat C — The reconciliation pain ────────────────────── */}
    <div class="layer-pain wrap section">
      <div class="layer-beat-head">
        <p class="beat-num">03</p>
        <h3>Two systems. A third to reconcile them.</h3>
      </div>

      <div class="pain-diagram" role="img" aria-label="Three disconnected document workflows">
        <div class="pain-app pain-app-write">
          <p class="pain-app-role">Draft</p>
          <p class="pain-app-name">Microsoft Word</p>
          <p class="pain-app-file"><code>term-sheet.docx</code></p>
        </div>
        <div class="pain-break" aria-hidden="true">
          <span class="pain-break-mark">
            <X size={14} stroke-width={2.5} aria-hidden="true" focusable="false" />
          </span>
          <span class="pain-break-label">manual paste</span>
        </div>
        <div class="pain-app pain-app-math">
          <p class="pain-app-role">Notation</p>
          <p class="pain-app-name">LaTeX · Overleaf</p>
          <p class="pain-app-file"><code>valuation.tex</code></p>
        </div>
        <div class="pain-break" aria-hidden="true">
          <span class="pain-break-mark">
            <X size={14} stroke-width={2.5} aria-hidden="true" focusable="false" />
          </span>
          <span class="pain-break-label">export to PDF</span>
        </div>
        <div class="pain-app pain-app-sign">
          <p class="pain-app-role">Signature</p>
          <p class="pain-app-name">DocuSign</p>
          <p class="pain-app-file"><code>executed.pdf</code></p>
        </div>
      </div>

      <p class="layer-caption pain-caption">
        Three workflows. No canonical document. The reconciliation is someone&rsquo;s
        job — and the executed PDF has no semantic relationship to the draft
        that was reviewed.
      </p>
    </div>

    {/* ─── Beat D — The hybrid ─────────────────────────────────── */}
    <div class="layer-beat wrap section layer-beat-hybrid">
      <div class="layer-beat-head">
        <p class="beat-num">04</p>
        <h3>Atto: one source, all three layers.</h3>
      </div>
      <LayerDemo label="Atto" filename="services-agreement.atto">
        <pre slot="source"><code><span class="tok-heading"># Services Agreement</span>

Between <span class="tok-emph">**Atto Technologies Inc.**</span> ("Vendor") and
<span class="tok-emph">**Example Corp.**</span>, effective
<span class="tok-emph">**April 23, 2026**</span>.

<span class="tok-heading">## Compensation</span>

Vendor will be paid in quarterly installments, with net present value:

<span class="tok-math">$$
PV = \sum_&#123;t=1&#125;^&#123;T&#125; \frac&#123;C_t&#125;&#123;(1 + r)^t&#125;
$$</span>

<span class="tok-directive">::signature-block</span>
<span class="tok-key">  party:</span> <span class="tok-string">Atto Technologies Inc.</span>
<span class="tok-key">  signer:</span> <span class="tok-string">Curtis Baldwinson</span>
<span class="tok-key">  title:</span> <span class="tok-string">CEO</span>
<span class="tok-key">  sign_order:</span> <span class="tok-string">1</span>
<span class="tok-directive">::</span></code></pre>

        <article slot="preview" class="atto-doc" style="border: none; padding: 0;">
          <h2 class="atto-doc-title">Services Agreement</h2>
          <p>
            Between <strong>Atto Technologies Inc.</strong> ("Vendor") and
            <strong>Example Corp.</strong>, effective
            <strong>April 23, 2026</strong>.
          </p>
          <h3>Compensation</h3>
          <p>Vendor will be paid in quarterly installments, with net present value:</p>
          <span class="atto-math-display">
            <span class="atto-math">PV</span> =
            <span class="atto-sum">
              <span class="lim">T</span>
              <span class="sym">Σ</span>
              <span class="lim"><span class="atto-math">t</span>=1</span>
            </span>
            <span class="atto-frac">
              <span class="num"><span class="atto-math">C<sub>t</sub></span></span>
              <span class="den">(1 + <span class="atto-math">r</span>)<sup><span class="atto-math">t</span></sup></span>
            </span>
          </span>
          <SignatureWidget
            party="Atto Technologies Inc."
            signer="Curtis Baldwinson"
            title="CEO"
            order={1}
            totalSigners={2}
          />
        </article>
      </LayerDemo>
      <p class="layer-caption">
        One source file. Markdown prose, LaTeX notation, and typed directives —
        all parsed to a single deterministic tree. Diffable in git, reviewable
        line-by-line, executable end-to-end.
      </p>
    </div>
  </section>

  {/* ─── Section 4 — Live Collaboration ───────────────────────── */}
  <section class="collab wrap section">
    <div class="collab-copy">
      <p class="eyebrow">Transport</p>
      <h2 class="section-heading">Real-time. By design.</h2>
      <p>
        Atto documents sync over MQTT with CRDT-based conflict resolution.
        Every section, every directive, every LaTeX block is an independent
        stream.
      </p>
      <p>
        A signing event never blocks an edit in progress. A dropped
        connection resumes from its last acknowledged patch. The broker is
        horizontally scalable — the protocol is not.
      </p>
    </div>
    <figure class="collab-diagram" aria-label="Atto transport architecture">
      <pre class="code-block"><code>Browser Editor
    │
    ▼  MQTT / QUIC
Atto Relay Broker
    │
    ▼
Document State Service ──── Patch Log
    │
    ▼
Baldwinson Protocol Layer</code></pre>
    </figure>
  </section>

  {/* ─── Section 5 — Document Lifecycle ───────────────────────── */}
  <section class="lifecycle wrap section">
    <p class="eyebrow">Lifecycle</p>
    <h2 class="section-heading">
      Draft, review, sign, freeze, execute — in one format.
    </h2>
    <p class="section-lede">
      Every stage is a typed transition, captured in the document and the
      patch log. There is no external state.
    </p>
    <ol class="stages" role="list">
      {lifecycle.map((stage, i) => (
        <li class="stage" data-active={i === 0}>
          <span class="stage-dot" aria-hidden="true"></span>
          <span class="stage-name">{stage.name}</span>
          <span class="stage-desc">{stage.desc}</span>
        </li>
      ))}
    </ol>
  </section>

  {/* ─── Section 6 — Comparison ───────────────────────────────── */}
  <section class="compare wrap section" aria-labelledby="compare-heading">
    <p class="eyebrow">Comparison</p>
    <h2 id="compare-heading" class="section-heading">
      Why teams switch.
    </h2>
    <div class="compare-wrap">
      <table>
        <thead>
          <tr>
            <th scope="col">Dimension</th>
            <th scope="col">Traditional</th>
            <th scope="col">Atto</th>
          </tr>
        </thead>
        <tbody>
          {rows.map(({ dim, trad, atto }) => (
            <tr>
              <th scope="row">{dim}</th>
              <td class="trad">{trad}</td>
              <td class="atto">{atto}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  {/* ─── Section 7 — CTA Banner ───────────────────────────────── */}
  <section class="cta-banner section-dark" aria-labelledby="cta-heading">
    <div class="wrap-default cta-inner">
      <h2 id="cta-heading">The document format for serious work.</h2>
      <a href="/waitlist" class="btn btn-on-dark">
        Join the waitlist <span aria-hidden="true">→</span>
      </a>
    </div>
  </section>
</Base>

<style>
  /* ─── Hero ──────────────────────────────────────────────────── */
  .hero {
    display: grid;
    /* `1fr 1fr` is implicitly `minmax(auto, 1fr) minmax(auto, 1fr)` —
       the auto min-size lets a column grow past 50% if its content's
       intrinsic min-size demands it. The hero AttoDemo's source <pre>
       has white-space: pre (no line breaks) so its min-content equals
       its longest line, which pushes the right column wider when the
       Source tab is active. That visibly shifts the right-anchored
       filename in the demo head between tabs. `minmax(0, 1fr)` pins
       both columns to exactly 50%; the pre stays contained by its
       own overflow-x: auto. */
    grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
    /* 64px gap (var(--space-16)) felt oversized on the now-wider
       1440px frame and stole horizontal room from the AttoDemo
       column. 40px (var(--space-10)) keeps the two columns visually
       distinct while giving the demo card meaningful extra width to
       breathe — net gain ~12px per column on large desktops. The
       single-column mobile layout below uses --space-12 (48px) for
       its vertical stack, where gap cost is cheaper. */
    gap: var(--space-10);
    align-items: start;
    min-height: 90vh;
    padding: var(--space-24) var(--space-8);
    max-width: var(--content-wide);
    margin: 0 auto;
  }

  .hero-copy h1 {
    font-family: var(--font-display);
    font-weight: 800;
    /* The shared --text-hero scale (clamp(3rem, 0.5rem + 7vw, 8rem))
       assumes near-full-width content and reaches 128px on large
       desktops, which overflowed the two-column hero. Going the
       other way (≤80px to fit "Structured documents" on one line in
       a ~660px column) traded too much hero impact. Compromise:
       cap at 96px and embrace the wrap — at large desktops the
       heading reads as three lines:
         Structured
         documents
         for work that matters.
       which is a deliberate stacked-typography pattern, not an
       overflow. `overflow-wrap: break-word` below stays as the
       safety net for any truly oversized word. */
    font-size: clamp(2.75rem, 1rem + 5vw, 6rem);
    letter-spacing: -0.02em;
    line-height: 0.95;
    margin-block: var(--space-6);
    /* Safety net: if a viewport/column ratio still leaves a single
       word too wide to fit, break it at the column edge instead of
       letting it bleed into the demo column. */
    overflow-wrap: break-word;
  }

  .primary-ink { color: var(--color-primary); }

  .hero-sub {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    max-width: 46ch;
    margin-bottom: var(--space-8);
  }

  .hero-demo {
    position: relative;
    /* Same containment pattern as `.docs-content` on the docs page:
       `min-width: 0` lets this grid item shrink below the intrinsic
       min-size of its children. Without it, on narrow mobile viewports
       (e.g. 390px iPhone 12 Pro) the AttoDemo's source <pre> longest
       line forces this column wider than the viewport, pushing the
       whole card past the page's left/right padding. With `min-width:
       0`, the column collapses to the available width and the pre
       scrolls internally via its own overflow-x: auto. */
    min-width: 0;
  }

  /* Symmetric containment for the copy column so a single ultra-long
     word (URL, code token) can't blow out the layout either. Text in
     this column wraps normally so the min-content is small in
     practice — this is a defensive belt-and-suspenders rule. */
  .hero-copy {
    min-width: 0;
  }

  @media (max-width: 1024px) {
    .hero {
      grid-template-columns: 1fr;
      gap: var(--space-12);
      min-height: auto;
      padding: var(--space-16) var(--space-6);
    }
  }

  /* ─── Problem ───────────────────────────────────────────────── */
  .problem h2 {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: var(--text-2xl);
    margin-block: var(--space-4) var(--space-10);
    max-width: 20ch;
  }

  .problem-body {
    display: grid;
    gap: var(--space-6);
    max-width: 68ch;
  }

  .problem-body p {
    font-size: var(--text-base);
    color: var(--color-text);
  }

  /* ─── Hybrid Explainer (four beats) ─────────────────────────
     Each .layer-beat is a self-contained story unit: header with
     beat number + inline h3, the LayerDemo component, and a caption
     paragraph below. Beats are padded vertically so the transitions
     feel paced, not crammed. */
  .layers-intro {
    padding-bottom: var(--space-8);
  }

  .layer-beat,
  .layer-pain {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    padding-block: var(--space-12);
    border-top: 1px solid var(--color-border);
  }

  .layer-beat-head {
    display: flex;
    align-items: baseline;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .beat-num {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.12em;
    color: var(--color-text-faint);
    margin: 0;
  }

  .layer-beat-head h3 {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: var(--text-2xl);
    margin: 0;
  }

  .layer-caption {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    max-width: 64ch;
  }

  /* The hybrid beat gets a subtle left-edge accent so it reads as the
     resolution of the preceding pain beat, not just another example. */
  .layer-beat-hybrid {
    position: relative;
  }

  .layer-beat-hybrid::before {
    content: '';
    position: absolute;
    inset-block: var(--space-8);
    left: calc(var(--space-4) * -1);
    width: 2px;
    background: var(--color-primary);
  }

  @media (max-width: 768px) {
    .layer-beat-hybrid::before {
      display: none;
    }
  }

  /* ─── Pain diagram (Beat C) ──────────────────────────────────
     Three "app" cards with broken-link indicators between them,
     visualizing the three-tool draft → typeset → sign workflow. */
  .pain-diagram {
    display: grid;
    grid-template-columns: 1fr auto 1fr auto 1fr;
    align-items: stretch;
    gap: var(--space-3);
    padding: var(--space-6);
    border: 1px solid var(--color-border);
    background: var(--color-bg);
  }

  .pain-app {
