---
import Base from '../layouts/Base.astro';
import AttoDemo from '../components/AttoDemo.astro';
import CreditCheckBlock from '../components/CreditCheckBlock.astro';
import FieldTable from '../components/FieldTable.astro';

const nav = [
  { id: 'overview', label: 'Overview' },
  { id: 'frontmatter', label: 'Frontmatter' },
  { id: 'sections', label: 'Sections' },
  { id: 'inline-formatting', label: 'Inline Formatting' },
  { id: 'inline-latex', label: 'Inline LaTeX' },
  { id: 'display-latex', label: 'Display LaTeX' },
  {
    id: 'directives',
    label: 'Directives',
    sub: [
      { id: 'directive-parties', label: '::parties' },
      { id: 'directive-signature', label: '::signature-block' },
      { id: 'directive-attachment', label: '::attachment' },
      { id: 'directive-callout', label: '::callout' },
      { id: 'directive-review', label: '::review-anchor' },
    ],
  },
  {
    id: 'font-references',
    label: 'Font References',
    sub: [
      { id: 'afrp-grammar', label: 'Identifier grammar' },
      { id: 'afrp-tiers', label: 'Two-tier namespace' },
      { id: 'afrp-resolution', label: 'Resolution & integrity' },
      { id: 'afrp-manifest', label: 'Registry manifest' },
    ],
  },
  {
    id: 'protocol-blocks',
    label: 'Protocol Blocks',
    sub: [
      { id: 'block-credit-check', label: ':::credit-check' },
    ],
  },
  { id: 'serialization', label: 'Serialization Rules' },
  { id: 'ast-mapping', label: 'Abstract Syntax Tree' },
  { id: 'mvp-scope', label: 'MVP Scope' },
];
---
<Base
  title="Docs"
  description="The Atto Hybrid Syntax specification — frontmatter, directives, serialization, and syntax-tree mapping."
>
  <div class="docs-layout wrap">
    <aside class="docs-sidebar" aria-label="Docs navigation">
      <p class="eyebrow">Syntax Spec v0</p>
      <nav>
        <ol role="list">
          {nav.map((item) => (
            <li>
              <a href={`#${item.id}`}>{item.label}</a>
              {item.sub && (
                <ol class="sub" role="list">
                  {item.sub.map((s) => (
                    <li><a href={`#${s.id}`}><code>{s.label}</code></a></li>
                  ))}
                </ol>
              )}
            </li>
          ))}
        </ol>
      </nav>
    </aside>

    <article class="docs-content">
      {/* ─── Overview ─────────────────────────────────────────── */}
      <section id="overview">
        <p class="eyebrow">01 — Overview</p>
        <div class="docs-title-row">
          <h1>The Atto Hybrid Syntax.</h1>
          <span class="docs-version" aria-label="Specification version">v0</span>
        </div>
        <p class="lede">
          Atto documents combine three layers into a single plain-text format.
          Markdown carries prose, LaTeX carries notation, and Atto directives
          carry structure. The parser walks them in order and produces a single
          deterministic Abstract Syntax Tree (AST).
        </p>
        <p>
          Every <code>.atto</code> file is human-readable, git-diffable, and
          stable under round-trip serialization. Equal ASTs produce equal byte
          streams.
        </p>
      </section>

      <hr class="rule" />

      {/* ─── Frontmatter ──────────────────────────────────────── */}
      <section id="frontmatter">
        <p class="eyebrow">02 — Frontmatter</p>
        <h2>Frontmatter.</h2>
        <p>
          Every document begins with a YAML frontmatter block delimited by
          <code>---</code>. Frontmatter declares document-level metadata:
          title, type, effective date, and any custom fields the document
          model accepts. Keys are serialized alphabetically on output.
        </p>

        <h3>Core fields</h3>
        <FieldTable
          caption="Core frontmatter fields"
          fields={[
            { name: 'title', type: 'string', required: true, description: 'Human-readable document title.' },
            { name: 'document_type', type: 'string', required: true, description: 'Registered document type, e.g. services_agreement, term_sheet.' },
            { name: 'authoring_mode', type: "'hybrid' | 'strict'", required: false, description: "Parse mode. 'hybrid' allows Markdown + LaTeX + directives. Defaults to 'hybrid'." },
            { name: 'effective_date', type: 'date (YYYY-MM-DD)', required: false, description: 'Date the document takes effect. Used by the protocol layer.' },
            { name: 'version', type: 'integer', required: false, description: 'Monotonic version counter, incremented on each signed revision.' },
            { name: 'jurisdiction', type: 'string', required: false, description: 'Governing-law jurisdiction, e.g. delaware.' },
          ]}
        />

        <h3>Example</h3>
        <AttoDemo filename="frontmatter.atto">
          <article class="atto-doc" slot="rendered">
            <header class="atto-doc-head">
              <p class="atto-doc-kicker">
                Services Agreement · Effective 2026-04-23 · v1 · Delaware
              </p>
              <h1 class="atto-doc-title">Services Agreement</h1>
            </header>
          </article>

          <pre class="code-block" slot="source"><code><span class="tok-comment">---</span>
<span class="tok-key">title:</span> <span class="tok-string">Services Agreement</span>
<span class="tok-key">document_type:</span> <span class="tok-string">services_agreement</span>
<span class="tok-key">authoring_mode:</span> <span class="tok-string">hybrid</span>
<span class="tok-key">effective_date:</span> <span class="tok-string">2026-04-23</span>
<span class="tok-key">jurisdiction:</span> <span class="tok-string">delaware</span>
<span class="tok-key">version:</span> <span class="tok-string">1</span>
<span class="tok-comment">---</span></code></pre>
        </AttoDemo>
      </section>

      <hr class="rule" />

      {/* ─── Sections ─────────────────────────────────────────── */}
      <section id="sections">
        <p class="eyebrow">03 — Sections</p>
        <h2>Sections.</h2>
        <p>
          Sections use standard Markdown headings, <code>##</code> through
          <code>######</code>. The parser tracks heading depth to build the
          section tree; heading text becomes the canonical section label.
          Top-level document title comes from frontmatter; body sections
          start at <code>##</code>.
        </p>

        <AttoDemo filename="sections.atto">
          <article class="atto-doc" slot="rendered">
            <section class="atto-doc-section">
              <h2>Payment Terms</h2>
              <p>Client shall pay within 15 days of invoice.</p>
              <h3>Late Fees</h3>
              <p>Overdue amounts accrue at 1.5% per day.</p>
              <h3>Currency</h3>
              <p>All amounts are in USD unless otherwise stated.</p>
            </section>
          </article>

          <pre class="code-block" slot="source"><code><span class="tok-heading">## Payment Terms</span>

Client shall pay within 15 days of invoice.

<span class="tok-heading">### Late Fees</span>

Overdue amounts accrue at 1.5% per day.

<span class="tok-heading">### Currency</span>

All amounts are in USD unless otherwise stated.</code></pre>
        </AttoDemo>
      </section>

      <hr class="rule" />

      {/* ─── Inline Formatting ────────────────────────────────── */}
      <section id="inline-formatting">
        <p class="eyebrow">04 — Inline Formatting</p>
        <h2>Inline formatting.</h2>
        <p>
          Standard Markdown inline syntax: <code>**bold**</code>,
          <code>*italic*</code>, <code>`code`</code>, and
          <code>[text](url)</code>. Raw HTML is rejected — the parser does
          not pass through tags. If Markdown cannot express what you need,
          use a directive.
        </p>

        <FieldTable
          caption="Inline syntax reference"
          fields={[
            { name: '**bold**', type: 'Strong', required: false, description: 'Strong emphasis. Renders bold.' },
            { name: '*italic*', type: 'Emphasis', required: false, description: 'Emphasis. Renders italic.' },
            { name: '`code`', type: 'Code', required: false, description: 'Inline code span. Uses the mono font.' },
            { name: '[text](url)', type: 'Link', required: false, description: 'Hyperlink. The parser validates URLs are absolute or atto://.' },
            { name: '~~strike~~', type: 'Strikethrough', required: false, description: 'Strikethrough for redlines and deletions.' },
          ]}
        />

        <h3>Example</h3>
        <AttoDemo filename="inline.atto">
          <article class="atto-doc" slot="rendered">
            <p>
              Client shall pay within <strong>15 days</strong> of invoice.
              See the <a href="#">master agreement</a> for definitions,
              including <em>reasonable notice</em>.
            </p>
            <p>
              Amounts invoiced under clause <code>3.1.a</code> are
              non-refundable once <del>delivered</del> accepted in writing.
            </p>
          </article>

          <pre class="code-block" slot="source"><code>Client shall pay within <span class="tok-emph">**15 days**</span> of invoice.
See the <span class="tok-emph">[master agreement](https://example.com)</span> for definitions, including <span class="tok-emph">*reasonable notice*</span>.

Amounts invoiced under clause <span class="tok-emph">`3.1.a`</span> are non-refundable once <span class="tok-emph">~~delivered~~</span> accepted in writing.</code></pre>
        </AttoDemo>
      </section>

      <hr class="rule" />

      {/* ─── Inline LaTeX ─────────────────────────────────────── */}
      <section id="inline-latex">
        <p class="eyebrow">05 — Inline LaTeX</p>
        <h2>Inline LaTeX.</h2>
        <p>
          Wrap an expression in single dollar signs: <code>$…$</code>.
          Renders in-line with surrounding prose at body text size. Dollar
          signs inside the expression must be escaped as <code>\$</code>.
        </p>

        <h3>Variables and operators</h3>
        <AttoDemo filename="math-simple.atto">
          <article class="atto-doc" slot="rendered">
            <p>
              The late fee is
              <span class="atto-math">L = B × 0.015</span> per day.
              Present value equals
              <span class="atto-math">PV = FV / (1 + r)<sup>n</sup></span>.
            </p>
          </article>

          <pre class="code-block" slot="source"><code>The late fee is <span class="tok-math">$L = B \times 0.015$</span> per day.
Present value equals <span class="tok-math">$PV = FV / (1 + r)^n$</span>.</code></pre>
        </AttoDemo>

        <h3>Greek letters and fractions</h3>
        <AttoDemo filename="math-greek.atto">
          <article class="atto-doc" slot="rendered">
            <p>
              Interest accrues at rate
              <span class="atto-math">α = r / n</span>
              where <span class="atto-math">n</span> is the number of
              compounding periods and
              <span class="atto-math">β ≈ 0.05</span> is the service margin.
            </p>
          </article>

          <pre class="code-block" slot="source"><code>Interest accrues at rate <span class="tok-math">$\alpha = \frac&#123;r&#125;&#123;n&#125;$</span> where <span class="tok-math">$n$</span> is the number of compounding periods and <span class="tok-math">$\beta \approx 0.05$</span> is the service margin.</code></pre>
        </AttoDemo>

        <h3>Subscripts and aggregates</h3>
        <AttoDemo filename="math-sub.atto">
          <article class="atto-doc" slot="rendered">
            <p>
              Total liability is bounded by
              <span class="atto-math">L<sub>max</sub> = Σ C<sub>i</sub></span>
              across all invoices
              <span class="atto-math">i ∈ &#123;1, …, n&#125;</span>.
            </p>
          </article>

          <pre class="code-block" slot="source"><code>Total liability is bounded by <span class="tok-math">$L_&#123;max&#125; = \sum C_i$</span> across all invoices <span class="tok-math">$i \in \&#123;1, \ldots, n\&#125;$</span>.</code></pre>
        </AttoDemo>
      </section>

      <hr class="rule" />

      {/* ─── Display LaTeX ────────────────────────────────────── */}
      <section id="display-latex">
        <p class="eyebrow">06 — Display LaTeX</p>
        <h2>Display LaTeX.</h2>
        <p>
          Wrap an expression in double dollar signs: <code>$$…$$</code> on
          their own lines. Renders as a centered display block, isolated
          from surrounding prose.
        </p>

        <h3>Compound interest</h3>
        <AttoDemo filename="display-compound.atto">
          <article class="atto-doc" slot="rendered">
            <p>The value after <span class="atto-math">t</span> years of compounding:</p>
            <span class="atto-math-display">
              A = P(1 + <sup>r</sup>&frasl;<sub>n</sub>)<sup>nt</sup>
            </span>
          </article>

          <pre class="code-block" slot="source"><code>The value after <span class="tok-math">$t$</span> years of compounding:

<span class="tok-math">$$
A = P\left(1 + \frac&#123;r&#125;&#123;n&#125;\right)^&#123;nt&#125;
$$</span></code></pre>
        </AttoDemo>

        <h3>Summation</h3>
        <AttoDemo filename="display-sum.atto">
          <article class="atto-doc" slot="rendered">
            <p>Post-money valuation aggregates pre-money plus all investment tranches:</p>
            <span class="atto-math-display">
              V<sub>post</sub> = V<sub>pre</sub> +&nbsp;
              <span style="font-size: 1.4em; vertical-align: -0.2em;">Σ</span>
              <sub style="font-size: 0.7em;">i=1</sub>
              <sup style="font-size: 0.7em;">n</sup>
              &nbsp;I<sub>i</sub>
            </span>
          </article>

          <pre class="code-block" slot="source"><code>Post-money valuation aggregates pre-money plus all investment tranches:

<span class="tok-math">$$
V_&#123;post&#125; = V_&#123;pre&#125; + \sum_&#123;i=1&#125;^&#123;n&#125; I_i
$$</span></code></pre>
        </AttoDemo>

        <h3>Aligned equations</h3>
        <AttoDemo filename="display-aligned.atto">
          <article class="atto-doc" slot="rendered">
            <p>The late-fee calculation, written out:</p>
            <span class="atto-math-display" style="text-align: left; padding-left: var(--space-8);">
              L &nbsp;&nbsp;= B × r<br />
              &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;= B × 0.015<br />
              &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;= 0.015B&nbsp;&nbsp;(per day)
            </span>
          </article>

          <pre class="code-block" slot="source"><code>The late-fee calculation, written out:

<span class="tok-math">$$
\begin&#123;aligned&#125;
L &amp;= B \times r \\
  &amp;= B \times 0.015 \\
  &amp;= 0.015 B \quad \text&#123;(per day)&#125;
\end&#123;aligned&#125;
$$</span></code></pre>
        </AttoDemo>
      </section>

      <hr class="rule" />

      {/* ─── Directives ───────────────────────────────────────── */}
      <section id="directives">
        <p class="eyebrow">07 — Directives</p>
        <h2>Directives.</h2>
        <p>
          Directives are typed semantic blocks. They open with
          <code>::name</code> on a line by itself, close with a bare
          <code>::</code>, and accept YAML-shaped content between. The parser
          validates directive names against a closed registry — unknown
          names are rejected at parse time.
        </p>

        {/* ─── ::parties ───────────────────────────────────────── */}
        <h3 id="directive-parties"><code>::parties</code></h3>
        <p>
          Declares the parties to the document. Each party is a list entry
          keyed first by <code>role</code>, then <code>name</code>. Optional
          <code>entity</code> and <code>jurisdiction</code> attributes
          describe the legal form.
        </p>

        <FieldTable
          caption="::parties entry fields"
          fields={[
            { name: 'role', type: 'string', required: true, description: 'Human-readable role label, e.g. Provider, Client, Investor.' },
            { name: 'name', type: 'string', required: true, description: 'Legal name of the party.' },
            { name: 'entity', type: 'string', required: false, description: 'Entity type slug, e.g. delaware_corp, llc, natural_person.' },
            { name: 'jurisdiction', type: 'string', required: false, description: 'Incorporation or residence jurisdiction.' },
          ]}
        />

        <AttoDemo filename="parties.atto">
          <aside class="atto-parties" slot="rendered" aria-label="Parties">
            <p class="atto-parties-label">Parties</p>
            <div class="atto-party">
              <span class="atto-party-role">Provider</span>
              <span class="atto-party-name">Baldwinson Corp.</span>
            </div>
            <div class="atto-party">
              <span class="atto-party-role">Client</span>
              <span class="atto-party-name">Example Client LLC</span>
            </div>
            <div class="atto-party">
              <span class="atto-party-role">Guarantor</span>
              <span class="atto-party-name">Atto Ventures</span>
            </div>
          </aside>

          <pre class="code-block" slot="source"><code><span class="tok-directive">::parties</span>
<span class="tok-key">- role:</span> <span class="tok-string">Provider</span>
  <span class="tok-key">name:</span> <span class="tok-string">Baldwinson Corp.</span>
  <span class="tok-key">entity:</span> <span class="tok-string">delaware_corp</span>
  <span class="tok-key">jurisdiction:</span> <span class="tok-string">delaware</span>
<span class="tok-key">- role:</span> <span class="tok-string">Client</span>
  <span class="tok-key">name:</span> <span class="tok-string">Example Client LLC</span>
  <span class="tok-key">entity:</span> <span class="tok-string">llc</span>
<span class="tok-key">- role:</span> <span class="tok-string">Guarantor</span>
  <span class="tok-key">name:</span> <span class="tok-string">Atto Ventures</span>
<span class="tok-directive">::</span></code></pre>
        </AttoDemo>

        {/* ─── ::signature-block ───────────────────────────────── */}
        <h3 id="directive-signature"><code>::signature-block</code></h3>
        <p>
          Declares one or more signatures. Each entry binds a
          <code>party</code> to a named <code>signer</code> with a
          <code>sign_order</code>. The Baldwinson Protocol layer enforces
          the order — signer 2 cannot countersign until signer 1 has.
        </p>

        <FieldTable
          caption="::signature-block entry fields"
          fields={[
            { name: 'party', type: 'string', required: true, description: 'Party name — must match a role declared in ::parties.' },
            { name: 'signer', type: 'string', required: true, description: 'Legal name of the individual countersigning.' },
            { name: 'sign_order', type: 'integer', required: true, description: 'Queue position for signing, 1-indexed.' },
            { name: 'title', type: 'string', required: false, description: "Signer's title at the party, e.g. CEO, Managing Partner." },
            { name: 'email', type: 'string', required: false, description: 'Contact email; used for signing invite dispatch.' },
          ]}
        />

        <AttoDemo filename="signature-block.atto">
          <aside class="atto-sig-block" slot="rendered" aria-label="Signed signature block">
            <div class="atto-sig-block-head">
              <p class="atto-sig-label">Signature Block</p>
              <span class="atto-sig-status" data-status="signed">Signed</span>
            </div>
            <div class="atto-sig-preview">
              <span class="atto-sig-script">Curtis Baldwinson</span>
            </div>
            <div class="atto-sig-entry">
              <p class="atto-sig-party">Baldwinson Corp.</p>
              <p class="atto-sig-signer">
                <span>Curtis Baldwinson</span>
                <span class="atto-sig-title">· CEO</span>
              </p>
              <p class="atto-sig-attest">
                <code>ed25519:AQ…dF</code>
                <span aria-hidden="true">·</span>
                <code>sha256:4c1f…a7</code>
              </p>
            </div>
          </aside>

          <pre class="code-block" slot="source"><code><span class="tok-directive">::signature-block</span>
<span class="tok-key">- party:</span> <span class="tok-string">Baldwinson Corp.</span>
  <span class="tok-key">signer:</span> <span class="tok-string">Curtis Baldwinson</span>
  <span class="tok-key">title:</span> <span class="tok-string">CEO</span>
  <span class="tok-key">email:</span> <span class="tok-string">curtis@baldwinson.co</span>
  <span class="tok-key">sign_order:</span> <span class="tok-string">1</span>
<span class="tok-key">- party:</span> <span class="tok-string">Example Client LLC</span>
  <span class="tok-key">signer:</span> <span class="tok-string">Jane Hart</span>
  <span class="tok-key">title:</span> <span class="tok-string">Managing Partner</span>
  <span class="tok-key">email:</span> <span class="tok-string">jane@example.com</span>
  <span class="tok-key">sign_order:</span> <span class="tok-string">2</span>
<span class="tok-directive">::</span></code></pre>
        </AttoDemo>

        {/* ─── ::attachment ────────────────────────────────────── */}
        <h3 id="directive-attachment"><code>::attachment</code></h3>
        <p>
          References an external file by content hash. The document treats
          the attachment as part of its canonical content; the freeze event
          verifies every hash before emitting <code>doc.freeze</code>.
        </p>

        <FieldTable
          caption="::attachment fields"
          fields={[
            { name: 'label', type: 'string', required: true, description: 'Human-readable label, e.g. Schedule A, Exhibit 1.' },
            { name: 'uri', type: 'uri', required: true, description: 'Location of the file. Accepts atto://, https://, or ipfs://.' },
            { name: 'sha256', type: 'hex', required: true, description: '64-character SHA-256 digest of the file contents.' },
            { name: 'media_type', type: 'string', required: false, description: 'IANA media type, e.g. application/pdf.' },
            { name: 'bytes', type: 'integer', required: false, description: 'File size in bytes. Used for UI display and integrity checks.' },
          ]}
        />

        <AttoDemo filename="attachment.atto">
          <aside class="atto-attachment" slot="rendered" aria-label="Attachment">
            <span class="atto-attachment-icon" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none"
                   stroke="currentColor" stroke-width="2"
                   stroke-linecap="round" stroke-linejoin="round">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                <polyline points="14 2 14 8 20 8" />
              </svg>
            </span>
            <div class="atto-attachment-body">
              <p class="atto-attachment-label">Schedule A</p>
              <p class="atto-attachment-meta">
                <code>atto://attach/schedule-a.pdf</code>
                <span>sha256:4c1f…a7</span>
                <span>·</span>
                <span>PDF · 128 KB</span>
              </p>
            </div>
            <a class="atto-attachment-action" href="#">Open ↗</a>
          </aside>

          <pre class="code-block" slot="source"><code><span class="tok-directive">::attachment</span>
<span class="tok-key">label:</span> <span class="tok-string">Schedule A</span>
<span class="tok-key">uri:</span> <span class="tok-string">atto://attach/schedule-a.pdf</span>
<span class="tok-key">sha256:</span> <span class="tok-string">4c1f...a7</span>
<span class="tok-key">media_type:</span> <span class="tok-string">application/pdf</span>
<span class="tok-key">bytes:</span> <span class="tok-string">131072</span>
<span class="tok-directive">::</span></code></pre>
        </AttoDemo>

        {/* ─── ::callout ───────────────────────────────────────── */}
        <h3 id="directive-callout"><code>::callout</code></h3>
        <p>
          A typed admonition. The <code>tone</code> attribute selects the
          visual and semantic treatment; an optional <code>title</code>
          gives the callout a one-line header. The body is parsed as
          Markdown.
        </p>

        <FieldTable
          caption="::callout fields"
          fields={[
            { name: 'tone', type: "'note' | 'info' | 'warning' | 'danger'", required: true, description: 'Visual treatment and semantic severity.' },
            { name: 'title', type: 'string', required: false, description: 'One-line heading shown next to the tone label.' },
          ]}
        />

        <h4 style="font-family: var(--font-display); font-weight: 700; font-size: var(--text-base); margin-block: var(--space-5) var(--space-2);">All tones</h4>
        <AttoDemo filename="callout-tones.atto">
          <div slot="rendered" style="display: flex; flex-direction: column; gap: var(--space-3);">
            <aside class="atto-callout" aria-label="Note callout">
              <div class="atto-callout-head">
                <span class="atto-callout-tone">Note</span>
                <span class="atto-callout-title">Definitions</span>
              </div>
              <p>Capitalized terms take the meanings given in §1.</p>
            </aside>

            <aside class="atto-callout" aria-label="Info callout">
              <div class="atto-callout-head">
                <span class="atto-callout-tone">Info</span>
                <span class="atto-callout-title">Reference</span>
              </div>
              <p>See the master agreement for fallback provisions.</p>
            </aside>

            <aside class="atto-callout" data-tone="warning" aria-label="Warning callout">
              <div class="atto-callout-head">
                <span class="atto-callout-tone">Warning</span>
                <span class="atto-callout-title">Review Required</span>
              </div>
              <p>This clause applies only on quarterly distributions.</p>
            </aside>

            <aside class="atto-callout" data-tone="danger" aria-label="Danger callout">
              <div class="atto-callout-head">
                <span class="atto-callout-tone">Danger</span>
                <span class="atto-callout-title">Irrevocable</span>
              </div>
              <p>Once executed, this waiver cannot be revoked without both parties' written consent.</p>
            </aside>
          </div>

          <pre class="code-block" slot="source"><code><span class="tok-directive">::callout</span>
<span class="tok-key">tone:</span> <span class="tok-string">note</span>
<span class="tok-key">title:</span> <span class="tok-string">Definitions</span>
Capitalized terms take the meanings given in §1.
<span class="tok-directive">::</span>

<span class="tok-directive">::callout</span>
<span class="tok-key">tone:</span> <span class="tok-string">info</span>
<span class="tok-key">title:</span> <span class="tok-string">Reference</span>
See the master agreement for fallback provisions.
<span class="tok-directive">::</span>

<span class="tok-directive">::callout</span>
<span class="tok-key">tone:</span> <span class="tok-string">warning</span>
<span class="tok-key">title:</span> <span class="tok-string">Review Required</span>
This clause applies only on quarterly distributions.
<span class="tok-directive">::</span>

<span class="tok-directive">::callout</span>
<span class="tok-key">tone:</span> <span class="tok-string">danger</span>
<span class="tok-key">title:</span> <span class="tok-string">Irrevocable</span>
Once executed, this waiver cannot be revoked without both parties&rsquo; written consent.
<span class="tok-directive">::</span></code></pre>
        </AttoDemo>

        {/* ─── ::review-anchor ─────────────────────────────────── */}
        <h3 id="directive-review"><code>::review-anchor</code></h3>
        <p>
          Anchors a review thread to a specific AST node. Comments attach
          to the anchor by <code>id</code>, not to line numbers — edits
          around the anchor do not orphan the thread. The body is the
          content under review.
        </p>

        <FieldTable
          caption="::review-anchor fields"
          fields={[
            { name: 'id', type: 'slug', required: true, description: 'Stable identifier for the review thread. Must be unique per document.' },
            { name: 'status', type: "'open' | 'pending' | 'resolved'", required: false, description: "Review state. Defaults to 'open'." },
            { name: 'assignee', type: 'string', required: false, description: 'Email of the reviewer responsible for resolving the thread.' },
            { name: 'tags', type: 'string[]', required: false, description: 'Free-form tags for filtering, e.g. [legal, pricing].' },
          ]}
        />

        <AttoDemo filename="review-anchor.atto">
          <aside class="atto-review" slot="rendered" data-status="pending" aria-label="Review anchor">
            <div class="atto-review-head">
              <span class="atto-review-status">Review pending</span>
              <span class="atto-review-meta">late-fee-review · counsel@example.com</span>
            </div>
            <div class="atto-review-body">
              <p>
                The late fee calculation in §3.2 is pending counsel approval.
                Current formula: <span class="atto-math">L = B × 0.015</span>
                per day.
              </p>
              <p class="atto-review-footer">
                2 comments · opened 3 days ago
              </p>
            </div>
          </aside>

          <pre class="code-block" slot="source"><code><span class="tok-directive">::review-anchor</span>
<span class="tok-key">id:</span> <span class="tok-string">late-fee-review</span>
<span class="tok-key">status:</span> <span class="tok-string">pending</span>
<span class="tok-key">assignee:</span> <span class="tok-string">counsel@example.com</span>
<span class="tok-key">tags:</span> <span class="tok-string">[legal, pricing]</span>
The late fee calculation in §3.2 is pending counsel approval.
Current formula: <span class="tok-math">$L = B \times 0.015$</span> per day.
<span class="tok-directive">::</span></code></pre>
        </AttoDemo>
      </section>

      <hr class="rule" />

      {/* ─── Font References (AFRP) ──────────────────────────────
           The Atto Font Registry Protocol defines a portable
           identifier grammar for font assets plus a resolution
           protocol that guarantees bit-exact reproducibility at
           signing time. Lives in the syntax spec because the
           identifier appears in document source; the resolution
           algorithm lives in the protocol layer spec. */}
      <section id="font-references">
        <p class="eyebrow">08 — Font References</p>
        <h2>Font references.</h2>
        <p>
          A document that can be signed must be renderable identically at
          any future time. The Atto Font Registry Protocol (AFRP) introduces
          a portable identifier grammar for font assets and a resolution
          protocol that binds every executed document to the exact font
          binaries present at signing.
        </p>

        <h3 id="afrp-grammar">Identifier grammar</h3>
        <p>
          A font reference is a sigil-prefixed identifier that may appear
          anywhere a font family is named — in frontmatter, in directive
          attributes, or in future typography directives. The grammar
          (ABNF summary):
        </p>

        <pre class="code-block"><code><span class="tok-key">font-reference</span>  = font-identifier [qualifier...]
<span class="tok-key">font-identifier</span> = form-a / form-b / form-c

<span class="tok-key">form-a</span>          = <span class="tok-string">"@/"</span> typeface-name [version-specifier]   <span class="tok-comment">; canonical</span>
<span class="tok-key">form-b</span>          = <span class="tok-string">"@"</span> scope <span class="tok-string">"/"</span> typeface-name [version-specifier]  <span class="tok-comment">; governed scope</span>
<span class="tok-key">form-c</span>          = host <span class="tok-string">"/"</span> typeface-name [version-specifier]      <span class="tok-comment">; permissionless URI</span>

<span class="tok-key">version-specifier</span> = <span class="tok-string">"@"</span> ( <span class="tok-string">"X.Y.Z"</span> | <span class="tok-string">"^X"</span> | <span class="tok-string">"^X.Y"</span> | <span class="tok-string">"~X.Y"</span> | <span class="tok-string">"latest"</span> | <span class="tok-string">"pinned"</span> )</code></pre>

        <p>
          Version semantics follow SemVer 2.0.0 exactly. <code>@latest</code>
          is valid but <em>must not</em> be used in documents intended for
          signing. <code>@pinned</code> is valid only in EXECUTED-state
          documents — it resolves to the exact binary hash recorded at
          signing time.
        </p>

        <h3 id="afrp-tiers">Two-tier namespace</h3>
        <p>
          AFRP defines two coexisting tiers over one resolution protocol.
          The permissionless tier guarantees the governed tier can never
          become a gatekeeper for the system.
        </p>

        <FieldTable
          caption="AFRP namespace tiers"
          fields={[
            { name: '@/Typeface', type: 'Canonical', required: false, description: 'Bare sigil. Resolves via the platform\'s canonical registry — identity is a property of the protocol, not any vendor deployment. Portable across all compliant Atto implementations without hardcoding a domain.' },
            { name: '@scope/Typeface', type: 'Governed', required: false, description: 'Registered scope (e.g. @velvetyne/Bagnard, @adobe/Garamond). Scopes are issued by the Atto Protocol Authority after identity verification, catalog audit, and license-transparency review. The Authority governs namespace identity, not font content.' },
            { name: 'host/Typeface', type: 'Permissionless', required: false, description: 'Any DNS host implementing the AFRP resolution interface. No registration, approval, or contact with any authority required. Equivalent openness to the World Wide Web itself.' },
          ]}
        />

        <h3>Examples</h3>
        <AttoDemo filename="frontmatter-fonts.atto">
          <article class="atto-doc" slot="rendered">
            <header class="atto-doc-head">
              <p class="atto-doc-kicker">
                Services Agreement · Fonts declared
              </p>
              <h1 class="atto-doc-title">Services Agreement</h1>
            </header>
            <section class="atto-doc-section">
              <h2>Typography</h2>
              <p>The body is set in <span class="atto-font-ref" data-tier="canonical">@/Lineal@^2</span> (canonical) with display headings in <span class="atto-font-ref" data-tier="scoped">@velvetyne/Bagnard@2.1.0</span> (governed scope). Signing pins both to an exact binary hash.</p>
              <p>An open-source fallback is loaded from <span class="atto-font-ref" data-tier="permissionless">fonts.example.com/Grotesk@~1.4</span> (permissionless).</p>
            </section>
          </article>

          <pre class="code-block" slot="source"><code><span class="tok-comment">---</span>
<span class="tok-key">title:</span> <span class="tok-string">Services Agreement</span>
<span class="tok-key">font_families:</span>
  <span class="tok-key">- role:</span> <span class="tok-string">body</span>
    <span class="tok-key">ref:</span>  <span class="tok-string">@/Lineal@^2</span>
  <span class="tok-key">- role:</span> <span class="tok-string">display</span>
    <span class="tok-key">ref:</span>  <span class="tok-string">@velvetyne/Bagnard@2.1.0</span>
  <span class="tok-key">- role:</span> <span class="tok-string">fallback</span>
    <span class="tok-key">ref:</span>  <span class="tok-string">fonts.example.com/Grotesk@~1.4</span>
<span class="tok-comment">---</span></code></pre>
        </AttoDemo>

        <h3 id="afrp-resolution">Resolution &amp; integrity</h3>
        <p>
          Resolution behavior depends on the document's lifecycle state.
          An EXECUTED document is renderable identically at any future
          time using exactly the font binaries present at signing.
        </p>

        <FieldTable
          caption="Font resolution by document state"
          fields={[
            { name: 'DRAFT', type: 'Lifecycle state', required: false, description: '@latest and range specifiers (^X, ~X.Y) resolve to the current highest matching version. Version drift is permitted and expected.' },
            { name: 'EXECUTED', type: 'Lifecycle state', required: false, description: 'All references resolve to @pinned — the exact binary hash recorded at signing. Any hash mismatch fails resolution. There is no fallback path.' },
          ]}
        />

        <p>
          The resolver algorithm is non-negotiable. Every compliant
          implementation MUST:
        </p>
        <ul>
          <li>Fetch the registry manifest from <code>/.well-known/afrp-manifest.json</code>.</li>
          <li>Verify the manifest's Ed25519 signature before trusting any field.</li>
          <li>Select a version satisfying the specifier.</li>
          <li>Download the font binary.</li>
          <li>Verify the binary's SHA-384 hash against the manifest's <code>integrity</code> field.</li>
          <li>Refuse any binary whose hash does not match.</li>
        </ul>

        <h3 id="afrp-manifest">Registry manifest</h3>
        <p>
          Every AFRP registry serves a signed manifest at
          <code>/.well-known/afrp-manifest.json</code>. The manifest carries
          per-version asset URLs, SHA-384 integrity hashes, machine-readable
          SPDX license metadata, and an Ed25519 signature over the
          JCS-canonicalized body.
        </p>

        <pre class="code-block"><code><span class="tok-comment">// /.well-known/afrp-manifest.json</span>
&#123;
  <span class="tok-key">"version"</span>: <span class="tok-string">17</span>,
  <span class="tok-key">"issued"</span>: <span class="tok-string">"2026-04-23T00:00:00Z"</span>,
  <span class="tok-key">"scopes"</span>: &#123;
    <span class="tok-key">""</span>: <span class="tok-string">"https://registry.atto.tech/canonical/"</span>,
    <span class="tok-key">"velvetyne"</span>: <span class="tok-string">"https://fonts.velvetyne.com/"</span>,
    <span class="tok-key">"adobe"</span>: <span class="tok-string">"https://fonts.adobe.com/afrp/"</span>
  &#125;,
  <span class="tok-key">"fonts"</span>: &#123;
    <span class="tok-key">"Lineal"</span>: &#123;
      <span class="tok-key">"versions"</span>: [<span class="tok-string">"2.0.0"</span>, <span class="tok-string">"2.1.0"</span>, <span class="tok-string">"2.1.1"</span>],
      <span class="tok-key">"latest"</span>: <span class="tok-string">"2.1.1"</span>,
      <span class="tok-key">"assets"</span>: &#123;
        <span class="tok-key">"2.1.1"</span>: &#123;
          <span class="tok-key">"woff2"</span>: <span class="tok-string">"https://cdn.../Lineal-2.1.1.woff2"</span>,
          <span class="tok-key">"integrity"</span>: <span class="tok-string">"sha384-oqVuAfXRK..."</span>
        &#125;
      &#125;,
      <span class="tok-key">"license"</span>: &#123; <span class="tok-key">"spdx"</span>: <span class="tok-string">"OFL-1.1"</span>, <span class="tok-key">"url"</span>: <span class="tok-string">"https://..."</span> &#125;
    &#125;
  &#125;,
  <span class="tok-key">"signature"</span>: <span class="tok-string">"ed25519:MEQCIB..."</span>
&#125;</code></pre>

        <p>
          A resolver that cannot verify the manifest signature falls back to
          the most recent cached manifest whose signature was verified. It
          never trusts an unsigned manifest and never trusts a binary whose
          hash is absent from the verified manifest.
        </p>
      </section>

      <hr class="rule" />

      {/* ─── Protocol Blocks (:::) ────────────────────────────────
           The triple-colon form is distinct from :: directives —
           it is an authoring surface that compiles to one or more
           :: directives at build time AND renders a UI component.
           Hosted in the syntax spec so authors can find it, but
           the compilation target lives in the Atto Leasing
           Protocol (ALP) spec. */}
      <section id="protocol-blocks">
        <p class="eyebrow">09 — Protocol Blocks</p>
        <h2>Protocol blocks.</h2>
        <p>
          Protocol blocks use the triple-colon form <code>:::name &#123; … &#125; :::</code>.
          Unlike regular <code>::</code> directives, a <code>:::</code> block is an
          authoring surface: it compiles to one or more <code>::</code> directives
          at document build time <em>and</em> renders a UI component the
          subject of the block sees when they open the document.
        </p>
        <p>
          Every <code>:::</code> block is disclosure-first. Fields the author
          might otherwise omit — purpose, requesting party, privacy scope —
          are REQUIRED. The document is invalid if any required disclosure
          field is missing. The tenant (or counterparty, or subject) reads
          the rendered form; an auditor can read the block source and verify
          exactly what consent was granted.
        </p>

        {/* ─── :::credit-check ─────────────────────────────────── */}
        <h3 id="block-credit-check"><code>:::credit-check</code></h3>
        <p>
          Declares a credit-check precondition for document execution. The
          block compiles to an <code>::alp:precondition:credit-check</code>
          directive evaluated by the Precondition Directive Evaluation Engine
          (PDEE), and simultaneously renders a tenant-facing consent form.
          The subject cannot sign the document until the precondition is
          satisfied.
        </p>

        <h4 style="font-family: var(--font-display); font-weight: 700; font-size: var(--text-base); margin-block: var(--space-5) var(--space-2);">Required disclosure fields</h4>
        <FieldTable
          caption=":::credit-check required fields"
          fields={[
            { name: 'id', type: 'string', required: true, description: 'Unique identifier within the document. Referenced by the compiled ::alp:precondition:credit-check directive as precondition_id.' },
            { name: 'party', type: 'string', required: true, description: 'party_id of the subject whose credit is being checked. MUST resolve to a party declared in the execution preamble.' },
            { name: 'purpose', type: 'string', required: true, description: 'Plain-language reason for the check. Shown verbatim in the tenant\'s consent disclosure and reported to the bureau adapter as permissible-purpose context. Template placeholders are rejected.' },
            { name: 'requesting_party', type: 'string', required: true, description: 'Legal name of the entity requesting the check. Shown verbatim in the consent disclosure. MUST match the landlord party\'s legal_name.' },
            { name: 'pull_type', type: "'hard_pull' | 'soft_pull'", required: true, description: 'Hard pulls appear on the consumer\'s credit file; soft pulls do not. A mismatch with the bureau adapter\'s actual pull type is a fatal validation error.' },
            { name: 'bureau', type: "'experian' | 'transunion' | 'equifax' | 'any'", required: true, description: "'any' permits the PDEE to select the bureau. The bureau actually used is recorded in execution metadata." },
            { name: 'score_model', type: "'FICO8' | 'FICO9' | 'VantageScore3' | 'VantageScore4'", required: true, description: 'Scoring model used for the pass/fail determination.' },
            { name: 'disclosed_to', type: 'array of enum | party_id', required: true, description: 'Who receives the pass/fail outcome. Values: requesting_party, named_parties, all_signatories, or specific party_ids. The raw score is NEVER shared through this field — only the pass/fail result.' },
            { name: 'extent', type: "'score_only' | 'full_report' | 'income_verified'", required: true, description: 'Breadth of the inquiry. See the extent reference below.' },
            { name: 'min_score', type: 'integer 300–850', required: true, description: 'Required when extent is score_only or income_verified. Minimum score for a pass outcome.' },
            { name: 'on_pass', type: "'proceed' | 'notify_requesting_party'", required: true, description: 'PDEE action on pass. proceed advances the execution queue.' },
            { name: 'on_fail', type: "'withdraw' | 'notify_requesting_party' | 'human_review'", required: true, description: 'PDEE action on fail. human_review pauses execution for review_window_hours before auto-withdrawing.' },
          ]}
        />

        <h4 style="font-family: var(--font-display); font-weight: 700; font-size: var(--text-base); margin-block: var(--space-6) var(--space-2);">Optional fields</h4>
        <FieldTable
          caption=":::credit-check optional fields"
          fields={[
            { name: 'immediate_feedback', type: 'boolean', required: false, description: 'Default false. When true, the rendered form shows the tenant a pass/fail result as soon as the bureau responds. When false, the tenant sees only a "submitted — awaiting review" state.' },
            { name: 'review_window_hours', type: 'integer', required: false, description: 'Only valid when on_fail = human_review. Default 48. Hours the requesting party has to decide before auto-withdrawal.' },
            { name: 'timeout_hours', type: 'integer', required: false, description: 'Default 48. Hours the PDEE waits for a bureau response before treating the check as failed.' },
          ]}
        />

        <h4 style="font-family: var(--font-display); font-weight: 700; font-size: var(--text-base); margin-block: var(--space-6) var(--space-2);">Extent levels</h4>
        <FieldTable
          caption="extent field values"
          fields={[
            { name: 'score_only', type: 'Score only', required: false, description: 'Credit score only. No tradeline detail, no account history. Lowest privacy impact. min_score is required.' },
            { name: 'full_report', type: 'Full report', required: false, description: 'Full consumer credit report including tradelines, inquiries, public records, and collections. Retained in execution metadata (encrypted, accessible only to requesting party). min_score optional.' },
            { name: 'income_verified', type: 'Score + income', required: false, description: 'Credit score plus income verification via payroll connector (Argyle, Pinwheel). Requires chained ::alp:precondition:income-verify. min_score is required and applies to the score component only.' },
          ]}
        />

        <h4 style="font-family: var(--font-display); font-weight: 700; font-size: var(--text-base); margin-block: var(--space-6) var(--space-2);">Example — residential lease</h4>
        <AttoDemo filename="credit-check.atto" label=":::credit-check">
          <div slot="rendered">
            <CreditCheckBlock
              requestingParty="Westbrook Property Management LLC"
              purpose="Residential tenancy application for 42 Elm Street, Unit 3B, Los Angeles, CA 90024. Requested by Westbrook Property Management LLC on behalf of property owner."
              scoreModel="FICO8"
              bureau="transunion"
              pullType="hard_pull"
              disclosedTo={["Westbrook Property Management LLC"]}
              immediateFeedback={false}
              onFail="human_review"
              reviewWindowHours={72}
            />
          </div>

          <pre class="code-block" slot="source"><code><span class="tok-directive">:::credit-check</span> &#123;
  <span class="tok-key">id</span>               = <span class="tok-string">"cc-residential-001"</span>
  <span class="tok-key">party</span>            = <span class="tok-string">"party-tenant-jane-doe"</span>

  <span class="tok-key">purpose</span>          = <span class="tok-string">"Residential tenancy application for 42 Elm Street,</span>
<span class="tok-string">                      Unit 3B, Los Angeles, CA 90024. Requested by</span>
<span class="tok-string">                      Westbrook Property Management LLC on behalf of</span>
<span class="tok-string">                      property owner."</span>

  <span class="tok-key">requesting_party</span> = <span class="tok-string">"Westbrook Property Management LLC"</span>
  <span class="tok-key">pull_type</span>        = <span class="tok-string">hard_pull</span>
  <span class="tok-key">bureau</span>           = <span class="tok-string">transunion</span>
  <span class="tok-key">score_model</span>      = <span class="tok-string">FICO8</span>

  <span class="tok-key">disclosed_to</span>     = [<span class="tok-string">requesting_party</span>]
  <span class="tok-key">extent</span>           = <span class="tok-string">score_only</span>
  <span class="tok-key">min_score</span>        = <span class="tok-string">680</span>

  <span class="tok-key">on_pass</span>          = <span class="tok-string">proceed</span>
  <span class="tok-key">on_fail</span>          = <span class="tok-string">human_review</span>
  <span class="tok-key">review_window_hours</span> = <span class="tok-string">72</span>

  <span class="tok-key">immediate_feedback</span> = <span class="tok-string">false</span>
  <span class="tok-key">timeout_hours</span>    = <span class="tok-string">24</span>
&#125;
<span class="tok-directive">:::</span></code></pre>
        </AttoDemo>

        <h4 style="font-family: var(--font-display); font-weight: 700; font-size: var(--text-base); margin-block: var(--space-6) var(--space-2);">Compilation to ALP</h4>
        <p>
          The <code>:::credit-check</code> block compiles mechanically to an
          <code>::alp:precondition:credit-check</code> directive at build
          time. The field mapping is exact:
        </p>

        <FieldTable
          caption="Compilation mapping"
          fields={[
            { name: 'id', type: '→ precondition_id', required: false, description: 'Direct mapping.' },
            { name: 'party', type: '→ subject_party_id', required: false, description: 'Direct mapping.' },
            { name: 'min_score / bureau / score_model / pull_type / timeout_hours', type: '→ same', required: false, description: 'Direct mapping of PDEE-relevant fields.' },
            { name: 'on_fail = withdraw', type: '→ failure_action = "withdraw"', required: false, description: 'Document enters WITHDRAWN on fail.' },
            { name: 'on_fail = notify_requesting_party', type: '→ failure_action = "notify_only"', required: false, description: 'Record failure; notify landlord; await their decision.' },
            { name: 'on_fail = human_review', type: '→ failure_action = "notify_only" + review_window annotation', required: false, description: 'Pauses at PRECONDITION_PENDING for review_window_hours.' },
            { name: 'purpose / requesting_party / disclosed_to / extent', type: '→ consent_scope.* fields', required: false, description: 'Embedded in the consent-scope object sent to the bureau adapter as permissible-purpose context.' },
            { name: 'immediate_feedback', type: '→ renderer directive only', required: false, description: 'Not forwarded to the PDEE. Purely controls what the rendered form shows the subject.' },
          ]}
        />

        <h4 style="font-family: var(--font-display); font-weight: 700; font-size: var(--text-base); margin-block: var(--space-6) var(--space-2);">Validation rules</h4>
        <p>A document containing a <code>:::credit-check</code> block is INVALID if any of the following are true:</p>
        <ul>
          <li><code>purpose</code> is absent, empty, or contains only template placeholder text (e.g. <code>[property address]</code>).</li>
          <li><code>requesting_party</code> does not match the <code>legal_name</code> of any declared party.</li>
          <li><code>party</code> does not resolve to a <code>party_id</code> in the execution preamble.</li>
          <li><code>pull_type = hard_pull</code> and <code>consent_scope</code> has not been completed before PDEE dispatch.</li>
          <li><code>extent</code> is <code>score_only</code> or <code>income_verified</code> and <code>min_score</code> is absent.</li>
          <li><code>on_fail = human_review</code> and <code>review_window_hours</code> is absent.</li>
          <li><code>disclosed_to</code> contains a party id not declared in the execution preamble.</li>
          <li>Two <code>:::credit-check</code> blocks in the same document share an <code>id</code>.</li>
          <li><code>immediate_feedback = true</code> and <code>on_fail = human_review</code> simultaneously — these are contradictory.</li>
        </ul>

        <p>
          Raw-score disclosure is non-negotiable: regardless of
          <code>disclosed_to</code>, the numeric score is NEVER exposed in
          the rendered document or any interface accessible to disclosed
          parties. Scores are stored encrypted in execution metadata,
          accessible only to the PDEE and, after execution, to the
          requesting party via a credentialed API call.
        </p>
      </section>

      <hr class="rule" />

      {/* ─── Serialization ────────────────────────────────────── */}
      <section id="serialization">
        <p class="eyebrow">10 — Serialization</p>
        <h2>Serialization rules.</h2>
        <p>
          Serialization is deterministic. Two ASTs that are structurally equal
          serialize to byte-identical output. The implications:
        </p>
        <ul>
          <li>Trailing whitespace is stripped on every line.</li>
          <li>Every block is separated by exactly one blank line.</li>
          <li>YAML keys in frontmatter and directives are sorted alphabetically.</li>
          <li>Line endings are <code>LF</code>, encoding is <code>UTF-8</code>.</li>
          <li>The final byte is a single newline.</li>
        </ul>
        <p>
          This makes <code>git diff</code> reflect semantic change, not
          formatting drift.
        </p>
      </section>

      <hr class="rule" />

      {/* ─── AST Mapping ──────────────────────────────────────── */}
      <section id="ast-mapping">
        <p class="eyebrow">11 — Abstract Syntax Tree</p>
        <h2>Abstract Syntax Tree mapping.</h2>
        <p>
          Each surface construct maps to a node type. The set is closed: the
          parser rejects unknown directives rather than silently passing them
          through.
        </p>
        <pre class="code-block"><code><span class="tok-key">document</span>     → Document &#123; frontmatter, children[] &#125;
<span class="tok-key">##...######</span>   → Section &#123; depth, title, children[] &#125;
<span class="tok-key">paragraph</span>    → Paragraph &#123; inlines[] &#125;
<span class="tok-key">**x**</span>        → Strong &#123; children[] &#125;
<span class="tok-key">*x*</span>          → Emphasis &#123; children[] &#125;
<span class="tok-key">`x`</span>          → Code &#123; value &#125;
<span class="tok-key">[text](url)</span>  → Link &#123; url, children[] &#125;
<span class="tok-key">$x$</span>          → MathInline &#123; tex &#125;
<span class="tok-key">$$x$$</span>        → MathDisplay &#123; tex &#125;
<span class="tok-key">::name</span>       → Directive &#123; name, attrs, body &#125;
<span class="tok-key">:::name</span>      → ProtocolBlock &#123; name, fields, compiled[] &#125;
<span class="tok-key">@/.../...</span>    → FontReference &#123; tier, scope, name, version &#125;</code></pre>
      </section>

      <hr class="rule" />

      {/* ─── MVP Scope ────────────────────────────────────────── */}
      <section id="mvp-scope">
        <p class="eyebrow">12 — MVP Scope</p>
        <h2>MVP scope.</h2>
        <p>
          The v0 parser implements the full set described above. The MVP
          runtime implements: frontmatter, sections, inline formatting, inline
          and display LaTeX, and the five core directives. Anything outside
          that set is a post-v0 extension.
        </p>
        <p>
          The signing pipeline targets <code>::signature-block</code> only.
          Other directives have no lifecycle effect in v0 — they render and
          serialize, but do not emit protocol events.
        </p>
        <p>
          Font references parse in v0 with the full identifier grammar, but
          the AFRP resolver — manifest fetch, Ed25519 verification, SHA-384
          integrity, pinning at signing — ships as a follow-on milestone.
          Documents authored today that declare font references will be
          compatible with the resolver when it lands.
        </p>
        <p>
          <code>:::</code> protocol blocks parse in v0 with validation,
          compile to their target <code>::</code> directives, and render
          their UI components. Live precondition evaluation (PDEE dispatch,
          bureau integration) is coordinated through the Atto Leasing
          Protocol spec and ships in the ALP runtime.
        </p>
      </section>
    </article>
  </div>
</Base>

