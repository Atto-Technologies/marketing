---
// Atto docs page. Content-collection driven.
//
// Every section of the spec lives as a standalone MDX file under
// `src/content/docs/`. Sidebar nav, section eyebrows, and ordering
// are all derived from the collection schema (see
// `src/content.config.ts`); authors edit one file, no cross-file
// synchronization required. Add a new section by dropping another
// MDX file with an `order:` value into `src/content/docs/` and it
// renders automatically.

import { getCollection, render } from 'astro:content';
import Base from '../layouts/Base.astro';
// Docs layout & typography. `.docs-`-prefixed selectors so the
// stylesheet is safe to import globally without leaking into other
// pages.
import '../styles/docs.css';

const entries = (await getCollection('docs')).slice().sort(
  (a, b) => a.data.order - b.data.order,
);

// Eagerly resolve <Content/> for every entry so the template stays
// synchronous below. Promise.all preserves order of `entries`.
const sections = await Promise.all(
  entries.map(async (entry) => {
    const { Content } = await render(entry);
    return {
      meta: entry.data,
      Content,
      eyebrow: `${String(entry.data.order).padStart(2, '0')} — ${entry.data.label}`,
    };
  }),
);

// Sidebar navigation derived directly from the collection.
const nav = sections.map(({ meta }) => ({
  id: meta.id,
  label: meta.label,
  sub: meta.sub ?? null,
}));
---
<Base
  title="Docs"
  description="The Atto document format: document header, sections, directives, protocol blocks, font references, serialization, and syntax-tree mapping."
>
  {/* Demo-only typefaces. EB Garamond stands in for @adobe/Garamond
      (same Garamond revival lineage) and Playfair Display stands in
      for @velvetyne/Bagnard (visually-distinct historical serif) in
      the §09 inline-reference example. Loaded here — not in Base —
      so other pages don't pay the request cost. */}
  <Fragment slot="head">
    <link
      href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,700;1,400&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap"
      rel="stylesheet"
    />
  </Fragment>

  <div class="docs-layout">
    <aside class="docs-sidebar" aria-label="Docs navigation">
      <p class="eyebrow">Atto Docs v0</p>
      <nav>
        <ol role="list">
          {nav.map((item) => (
            <li>
              <a href={`#${item.id}`}>{item.label}</a>
              {item.sub && (
                <ol class="sub" role="list">
                  {item.sub.map((s) => (
                    <li><a href={`#${s.id}`}><code>{s.label}</code></a></li>
                  ))}
                </ol>
              )}
            </li>
          ))}
        </ol>
      </nav>
    </aside>

    <article class="docs-content">
      {sections.map(({ meta, Content, eyebrow }, idx) => (
        <>
          {idx > 0 && <hr class="rule" />}
          <section id={meta.id}>
            <p class="eyebrow">{eyebrow}</p>
            {meta.headingLevel === 1 ? (
              <div class="docs-title-row">
                <h1>{meta.title}</h1>
                {meta.versionBadge && (
                  <span class="docs-version" aria-label="Specification version">
                    {meta.versionBadge}
                  </span>
                )}
              </div>
            ) : (
              <h2>{meta.title}</h2>
            )}
            <Content />
          </section>
        </>
      ))}
    </article>
  </div>
</Base>
