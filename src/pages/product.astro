---
import Base from '../layouts/Base.astro';
import AttoDemo from '../components/AttoDemo.astro';
import CreditCheckBlock from '../components/CreditCheckBlock.astro';
---
<Base
  title="Product"
  description="A structured document editor with a legally-aware lifecycle."
>
  {/* ─── Hero ─────────────────────────────────────────────────── */}
  <section class="prod-hero wrap-default">
    <p class="eyebrow">Product</p>
    <h1>
      Everything Word isn&rsquo;t.
    </h1>
    <p class="lede">
      A structured document editor with a legally-aware lifecycle. Author in
      Markdown, notate in LaTeX, execute through the Baldwinson Protocol.
    </p>
    <div class="hero-ctas">
      <a href="#syntax" class="btn btn-primary">
        See the syntax <span aria-hidden="true">→</span>
      </a>
      <a href="/docs" class="btn btn-secondary">Read the spec</a>
    </div>
  </section>

  <hr class="rule" />

  {/* ─── Feature 1 — Hybrid Authoring Syntax ──────────────────── */}
  <section id="syntax" class="feature wrap section">
    <div class="feature-copy">
      <p class="eyebrow">01 — Syntax</p>
      <h2>Hybrid authoring syntax.</h2>
      <p>
        Markdown for humans. LaTeX for notation. Atto for structure. The three
        layers parse into a single canonical Abstract Syntax Tree (AST) and
        serialize back losslessly.
      </p>
      <p>
        Every file is plain text. Git-compatible. Human-readable. Diffable.
        What you write is what ships.
      </p>
    </div>
    <div class="feature-demo">
      <AttoDemo filename="term-sheet.atto">
        <article class="atto-doc" slot="rendered">
          <header class="atto-doc-head">
            <p class="atto-doc-kicker">Term Sheet · Draft</p>
            <h1 class="atto-doc-title">Series A Term Sheet</h1>
          </header>

          <aside class="atto-parties" aria-label="Parties">
            <p class="atto-parties-label">Parties</p>
            <div class="atto-party">
              <span class="atto-party-role">Company</span>
              <span class="atto-party-name">Baldwinson Corp.</span>
            </div>
            <div class="atto-party">
              <span class="atto-party-role">Investor</span>
              <span class="atto-party-name">Atto Ventures</span>
            </div>
          </aside>

          <section class="atto-doc-section">
            <h2>Valuation</h2>
            <p>
              Pre-money valuation shall be <strong>$12,000,000</strong>.
            </p>
            <p>
              The post-money cap table reflects
              <span class="atto-math">P<sub>post</sub> = P<sub>pre</sub> + I</span>.
            </p>
          </section>
        </article>

        <pre class="code-block" slot="source"><code><span class="tok-comment">---</span>
<span class="tok-key">title:</span> <span class="tok-string">Series A Term Sheet</span>
<span class="tok-key">document_type:</span> <span class="tok-string">term_sheet</span>
<span class="tok-key">authoring_mode:</span> <span class="tok-string">hybrid</span>
<span class="tok-comment">---</span>

<span class="tok-directive">::parties</span>
<span class="tok-key">- role:</span> <span class="tok-string">Company</span>
  <span class="tok-key">name:</span> <span class="tok-string">Baldwinson Corp.</span>
<span class="tok-key">- role:</span> <span class="tok-string">Investor</span>
  <span class="tok-key">name:</span> <span class="tok-string">Atto Ventures</span>
<span class="tok-directive">::</span>

<span class="tok-heading">## Valuation</span>

Pre-money valuation shall be <span class="tok-emph">**$12,000,000**</span>.

The post-money cap table reflects <span class="tok-math">$P_&#123;post&#125; = P_&#123;pre&#125; + I$</span>.</code></pre>
      </AttoDemo>
    </div>
  </section>

  {/* ─── Feature 2 — Directive Blocks ─────────────────────────── */}
  <section class="feature feature-reverse section-surface">
    <div class="wrap section feature-grid">
      <div class="feature-copy">
        <p class="eyebrow">02 — Directives</p>
        <h2>Typed semantic blocks.</h2>
        <p>
          Parties, signatures, attachments, callouts, review anchors. Each is
          a first-class node in the AST — not cosmetic markup. The parser
          validates them; the protocol acts on them.
        </p>
        <p>
          Directives can be nested, referenced, and queried. A signature block
          knows which party it belongs to. An attachment knows whether it has
          been verified.
        </p>
      </div>
      <div class="feature-demo feature-demo-grid">
        <AttoDemo filename="parties.atto" label="::parties">
          <aside class="atto-parties" slot="rendered" aria-label="Parties">
            <p class="atto-parties-label">Parties</p>
            <div class="atto-party">
              <span class="atto-party-role">Provider</span>
              <span class="atto-party-name">Baldwinson Corp.</span>
            </div>
            <div class="atto-party">
              <span class="atto-party-role">Client</span>
              <span class="atto-party-name">Example Client LLC</span>
            </div>
          </aside>

          <pre class="code-block" slot="source"><code><span class="tok-directive">::parties</span>
<span class="tok-key">- role:</span> <span class="tok-string">Provider</span>
  <span class="tok-key">name:</span> <span class="tok-string">Baldwinson Corp.</span>
<span class="tok-key">- role:</span> <span class="tok-string">Client</span>
  <span class="tok-key">name:</span> <span class="tok-string">Example Client LLC</span>
<span class="tok-directive">::</span></code></pre>
        </AttoDemo>

        <AttoDemo filename="signature.atto" label="::signature-block">
          <aside class="atto-sig-block" slot="rendered" aria-label="Signed signature block">
            <div class="atto-sig-block-head">
              <p class="atto-sig-label">Signature Block</p>
              <span class="atto-sig-status" data-status="signed">Signed</span>
            </div>
            <div class="atto-sig-preview">
              <span class="atto-sig-script">Jane Hart</span>
            </div>
            <div class="atto-sig-entry">
              <p class="atto-sig-party">Atto Ventures</p>
              <p class="atto-sig-signer">
                <span>Jane Hart</span>
                <span class="atto-sig-title">· Managing Partner</span>
              </p>
              <p class="atto-sig-attest">
                <code>ed25519:AQ…dF</code>
                <span aria-hidden="true">·</span>
                <code>sha256:4c1f…a7</code>
              </p>
            </div>
          </aside>

          <pre class="code-block" slot="source"><code><span class="tok-directive">::signature-block</span>
<span class="tok-key">- party:</span> <span class="tok-string">Atto Ventures</span>
  <span class="tok-key">signer:</span> <span class="tok-string">Jane Hart</span>
  <span class="tok-key">title:</span> <span class="tok-string">Managing Partner</span>
  <span class="tok-key">sign_order:</span> <span class="tok-string">2</span>
<span class="tok-directive">::</span></code></pre>
        </AttoDemo>

        <AttoDemo filename="callout.atto" label="::callout">
          <aside class="atto-callout" slot="rendered" data-tone="warning" aria-label="Callout">
            <div class="atto-callout-head">
              <span class="atto-callout-tone">Warning</span>
              <span class="atto-callout-title">Review Required</span>
            </div>
            <p>This clause applies only on quarterly distributions.</p>
          </aside>

          <pre class="code-block" slot="source"><code><span class="tok-directive">::callout</span>
<span class="tok-key">tone:</span> <span class="tok-string">warning</span>
<span class="tok-key">title:</span> <span class="tok-string">Review Required</span>
This clause applies only on quarterly distributions.
<span class="tok-directive">::</span></code></pre>
        </AttoDemo>
      </div>
    </div>
  </section>

  {/* ─── Feature 3 — LaTeX Notation ───────────────────────────── */}
  <section class="feature wrap section">
    <div class="feature-copy">
      <p class="eyebrow">03 — Notation</p>
      <h2>LaTeX, natively.</h2>
      <p>
        Inline and display math render in place — no insert-object dance, no
        screenshot of a formula. The editor preserves the source; the renderer
        shows the notation.
      </p>
      <p>
        For financial schedules, legal definitions, or scientific content,
        notation is content. Atto treats it that way.
      </p>
    </div>
    <div class="feature-demo feature-demo-grid">
      <AttoDemo filename="inline-math.atto" label="Inline">
        <article class="atto-doc" slot="rendered">
          <p>
            The late fee is <span class="atto-math">L = B × 0.015</span> per day.
          </p>
        </article>

        <pre class="code-block" slot="source"><code>The late fee is <span class="tok-math">$L = B \times 0.015$</span> per day.</code></pre>
      </AttoDemo>

      <AttoDemo filename="display-math.atto" label="Display">
        <article class="atto-doc" slot="rendered">
          <p>Compound interest over <span class="atto-math">n</span> periods:</p>
          <span class="atto-math-display">
            A = P(1 + <sup>r</sup>&frasl;<sub>n</sub>)<sup>nt</sup>
          </span>
        </article>

        <pre class="code-block" slot="source"><code>Compound interest over <span class="tok-math">$n$</span> periods:

<span class="tok-math">$$
A = P\left(1 + \frac&#123;r&#125;&#123;n&#125;\right)^&#123;nt&#125;
$$</span></code></pre>
      </AttoDemo>
    </div>
  </section>

  {/* ─── Feature 4 — Signing and Freeze ───────────────────────── */}
  <section class="feature feature-reverse section-surface">
    <div class="wrap section feature-grid">
      <div class="feature-copy">
        <p class="eyebrow">04 — Lifecycle</p>
        <h2>Signing and freeze.</h2>
        <p>
          When every required signer has countersigned, the document
          transitions to <span class="inline-code">frozen</span>. From that
          point, the content is immutable and the Baldwinson Protocol layer
          fires execution events.
        </p>
        <p>
          Every state transition is an MQTT event. Every event is recorded in
          the patch log. There is no &ldquo;which version was signed&rdquo;
          question.
        </p>
      </div>
      <figure class="feature-demo">
        <figcaption class="code-caption">lifecycle/signing</figcaption>
        <pre class="code-block"><code><span class="tok-comment"># topic: atto/doc/&#123;id&#125;/lifecycle</span>
<span class="tok-key">event:</span> <span class="tok-string">sign.intent</span>
<span class="tok-key">party:</span>  <span class="tok-string">baldwinson-corp</span>
<span class="tok-key">signer:</span> <span class="tok-string">curtis@baldwinson.co</span>
<span class="tok-key">order:</span>  <span class="tok-string">1</span>
<span class="tok-key">at:</span>     <span class="tok-string">2026-04-23T18:04:12Z</span>
---
<span class="tok-key">event:</span> <span class="tok-string">sign.accept</span>
<span class="tok-key">sig:</span>   <span class="tok-string">ed25519:AQ...dF</span>
<span class="tok-key">hash:</span>  <span class="tok-string">sha256:4c1f...a7</span>
---
<span class="tok-key">event:</span> <span class="tok-string">doc.freeze</span>
<span class="tok-key">root:</span>  <span class="tok-string">sha256:8b22...e9</span>
<span class="tok-key">final:</span> <span class="tok-string">true</span></code></pre>
      </figure>
    </div>
  </section>

  {/* ─── Feature 5 — Font Provenance (AFRP) ───────────────────
       Fonts are part of the document's cryptographic signature,
       not just its presentation. The two-tier namespace
       (permissionless URIs + governed @-sigils) and signed
       manifest flow make documents renderable identically at
       any future time. */}
  <section class="feature wrap section">
    <div class="feature-copy">
      <p class="eyebrow">05 — Provenance</p>
      <h2>Fonts as part of the signature.</h2>
      <p>
        An executed document must render identically in a year, or five,
        or twenty. Atto treats the font binary as part of the execution
        identity — not a presentational afterthought served by whoever
        happens to be hosting.
      </p>
      <p>
        The Atto Font Registry Protocol (AFRP) gives every reference a
        portable identifier, a cryptographically-signed registry manifest,
        and a SHA-384 integrity hash per binary. At signing, every
        reference is pinned. Any drift — a re-released version, a mutated
        binary, a missing asset — fails resolution.
      </p>
    </div>
    <div class="feature-demo feature-demo-grid">
      <AttoDemo filename="font-refs.atto" label="Identifier grammar">
        <article class="atto-doc" slot="rendered">
          <section class="atto-doc-section">
            <h3>Three reference forms</h3>
            <p>
              Canonical, bare and portable:
              <span class="atto-font-ref" data-tier="canonical">@/Lineal@^2</span>
            </p>
            <p>
              Governed scope, identity-verified registry:
              <span class="atto-font-ref" data-tier="scoped">@velvetyne/Bagnard@2.1.0</span>
            </p>
            <p>
              Permissionless, any compliant host:
              <span class="atto-font-ref" data-tier="permissionless">fonts.example.com/Grotesk@~1.4</span>
            </p>
          </section>
        </article>

        <pre class="code-block" slot="source"><code><span class="tok-comment">---</span>
<span class="tok-key">font_families:</span>
  <span class="tok-key">- role:</span> <span class="tok-string">body</span>
    <span class="tok-key">ref:</span>  <span class="tok-string">@/Lineal@^2</span>
  <span class="tok-key">- role:</span> <span class="tok-string">display</span>
    <span class="tok-key">ref:</span>  <span class="tok-string">@velvetyne/Bagnard@2.1.0</span>
  <span class="tok-key">- role:</span> <span class="tok-string">fallback</span>
    <span class="tok-key">ref:</span>  <span class="tok-string">fonts.example.com/Grotesk@~1.4</span>
<span class="tok-comment">---</span></code></pre>
      </AttoDemo>

      <AttoDemo filename="afrp-manifest" label="Signed manifest">
        <figure class="feature-demo-diagram" slot="rendered">
          <figcaption class="code-caption">.well-known/afrp-manifest.json</figcaption>
          <pre class="code-block"><code><span class="tok-key">"fonts"</span>: &#123;
  <span class="tok-key">"Lineal"</span>: &#123;
    <span class="tok-key">"versions"</span>: [<span class="tok-string">"2.0.0"</span>, <span class="tok-string">"2.1.0"</span>, <span class="tok-string">"2.1.1"</span>],
    <span class="tok-key">"assets"</span>: &#123;
      <span class="tok-key">"2.1.1"</span>: &#123;
        <span class="tok-key">"woff2"</span>: <span class="tok-string">"https://cdn.../Lineal-2.1.1.woff2"</span>,
        <span class="tok-key">"integrity"</span>: <span class="tok-string">"sha384-oqVu…"</span>
      &#125;
    &#125;
  &#125;
&#125;,
<span class="tok-key">"signature"</span>: <span class="tok-string">"ed25519:MEQCIB…"</span></code></pre>
        </figure>

        <pre class="code-block" slot="source"><code><span class="tok-comment"># Resolver contract (non-negotiable)</span>
<span class="tok-key">1.</span> fetch manifest at <span class="tok-string">/.well-known/afrp-manifest.json</span>
<span class="tok-key">2.</span> verify <span class="tok-string">ed25519</span> signature on JCS-canonicalized body
<span class="tok-key">3.</span> select version matching specifier
<span class="tok-key">4.</span> download binary
<span class="tok-key">5.</span> verify <span class="tok-string">sha384</span> hash against manifest integrity
<span class="tok-key">6.</span> refuse any binary whose hash does not match</code></pre>
      </AttoDemo>
    </div>
  </section>

  {/* ─── Feature 6 — Credit-Gated Execution ───────────────────
       Execution can depend on external data. The :::credit-check
       block is a disclosure-first authoring surface: required
       fields make the consent surface self-documenting, the same
       source renders both the PDEE precondition directive and
       the tenant-facing UI. */}
  <section class="feature feature-reverse section-surface">
    <div class="wrap section feature-grid">
      <div class="feature-copy">
        <p class="eyebrow">06 — Preconditions</p>
        <h2>Execution can gate on external data.</h2>
        <p>
          Signatures are not the only thing a document might wait on. A
          residential lease might need a credit check. A loan application
          might need income verification. A vendor agreement might need
          insurance verification.
        </p>
        <p>
          <code>:::credit-check</code> is the first of Atto&rsquo;s
          <code>:::</code> protocol blocks — authoring surfaces that compile
          to precondition directives <em>and</em> render the tenant-facing
          consent form from the same source. Required disclosure fields
          (purpose, requesting party, privacy scope, pull type) make the
          document self-documenting. What you write is what the subject
          reads. What the subject reads is what the bureau is told.
        </p>
      </div>
      <div class="feature-demo">
        <AttoDemo filename="credit-check.atto" label=":::credit-check">
          <div slot="rendered">
            <CreditCheckBlock
              requestingParty="Westbrook Property Management LLC"
              purpose="Residential tenancy application for 42 Elm Street, Unit 3B, Los Angeles, CA 90024."
              scoreModel="FICO8"
              bureau="transunion"
              pullType="hard_pull"
              disclosedTo={["Westbrook Property Management LLC"]}
              immediateFeedback={false}
              onFail="human_review"
              reviewWindowHours={72}
            />
          </div>

          <pre class="code-block" slot="source"><code><span class="tok-directive">:::credit-check</span> &#123;
  <span class="tok-key">id</span>               = <span class="tok-string">"cc-001"</span>
  <span class="tok-key">party</span>            = <span class="tok-string">"party-tenant"</span>

  <span class="tok-key">purpose</span>          = <span class="tok-string">"Residential tenancy application</span>
<span class="tok-string">                      for 42 Elm Street, Unit 3B."</span>
  <span class="tok-key">requesting_party</span> = <span class="tok-string">"Westbrook Property Management LLC"</span>
  <span class="tok-key">pull_type</span>        = <span class="tok-string">hard_pull</span>
  <span class="tok-key">bureau</span>           = <span class="tok-string">transunion</span>
  <span class="tok-key">score_model</span>      = <span class="tok-string">FICO8</span>

  <span class="tok-key">disclosed_to</span>     = [<span class="tok-string">requesting_party</span>]
  <span class="tok-key">extent</span>           = <span class="tok-string">score_only</span>
  <span class="tok-key">min_score</span>        = <span class="tok-string">680</span>

  <span class="tok-key">on_pass</span>          = <span class="tok-string">proceed</span>
  <span class="tok-key">on_fail</span>          = <span class="tok-string">human_review</span>
  <span class="tok-key">review_window_hours</span> = <span class="tok-string">72</span>
&#125;
<span class="tok-directive">:::</span></code></pre>
        </AttoDemo>
      </div>
    </div>
  </section>

  {/* ─── CTA ──────────────────────────────────────────────────── */}
  <section class="cta-banner section-dark" aria-labelledby="cta-heading">
    <div class="wrap-default cta-inner">
      <h2 id="cta-heading">Git-compatible. Human-readable. Protocol-native.</h2>
      <a href="/pricing" class="btn btn-on-dark">
        See pricing <span aria-hidden="true">→</span>
      </a>
    </div>
  </section>
</Base>

<style>
  .prod-hero {
    padding-block: var(--space-24) var(--space-16);
  }

  .prod-hero h1 {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: var(--text-3xl);
    letter-spacing: -0.02em;
    margin-block: var(--space-5) var(--space-6);
    max-width: 16ch;
  }

  .prod-hero .lede {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    max-width: 56ch;
    margin-bottom: var(--space-8);
  }

  /* `.hero-ctas` is shared — see base.css. */

  /* Feature layouts */
  .feature {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-16);
    align-items: start;
  }

  .feature-reverse { display: block; }

  .feature-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-16);
    align-items: start;
  }

  .feature-reverse .feature-copy {
    order: 2;
  }

  .feature-copy h2 {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: var(--text-2xl);
    margin-block: var(--space-4);
    max-width: 18ch;
  }

  .feature-copy p {
    color: var(--color-text);
    max-width: 52ch;
    margin-bottom: var(--space-4);
  }

  .feature-demo-grid {
    display: grid;
    gap: var(--space-5);
  }

  .demo-label {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-muted);
    margin-bottom: var(--space-2);
  }

  .code-caption {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    margin-bottom: var(--space-2);
    text-transform: lowercase;
    letter-spacing: 0.02em;
  }

  .inline-code {
    font-family: var(--font-mono);
    font-size: 0.95em;
    padding: 0.1em 0.35em;
    background: var(--color-code-bg);
    border: 1px solid var(--color-border);
    color: var(--color-primary);
  }

  @media (max-width: 900px) {
    .feature,
    .feature-grid {
      grid-template-columns: 1fr;
      gap: var(--space-10);
    }

    .feature-reverse .feature-copy {
      order: 0;
    }
  }

  /* CTA banner styles are shared — see base.css. */
</style>
