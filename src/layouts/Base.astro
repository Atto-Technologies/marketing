---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/base.css';

export interface Props {
  title: string;
  description?: string;
  /** Optional per-page social card override. Falls back to `/og-image.svg`. */
  ogImage?: string;
}

const {
  title,
  description = 'Atto — structured documents for high-stakes work.',
  ogImage = '/og-image.svg',
} = Astro.props;

const site = Astro.site ?? new URL('https://atto.tech');
const canonical = new URL(Astro.url.pathname, site).toString();
const absoluteOgImage = new URL(ogImage, site).toString();
const fullTitle = `${title} — Atto`;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="light dark" />
    <meta name="theme-color" content="#F8F7F4" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#141311" media="(prefers-color-scheme: dark)" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <title>{fullTitle}</title>

    {/* Open Graph */}
    <meta property="og:site_name" content="Atto" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={absoluteOgImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Atto — structured documents for high-stakes work" />

    {/* Twitter */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={absoluteOgImage} />

    {/* Icons — SVG preferred, with touch icon for iOS home screen. */}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.svg" />
    <link rel="mask-icon" href="/favicon.svg" color="#01696F" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@500;600;700;800&family=Instrument+Sans:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Geist+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />

    {/* Per-page head slot — lets specific pages inject extra stylesheet
        links, preload hints, or meta tags without paying the cost on
        every page. Used by docs.astro to load demo-only typefaces. */}
    <slot name="head" />

    {/* Apply theme before first paint — prevents FOUC on navigation. */}
    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem('atto-theme');
          var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          var theme = stored === 'dark' || stored === 'light'
            ? stored
            : (prefersDark ? 'dark' : 'light');
          document.documentElement.setAttribute('data-theme', theme);
        } catch (e) {
          document.documentElement.setAttribute('data-theme', 'light');
        }
      })();
    </script>
  </head>
  <body>
    <Nav />
    <main id="main">
      <slot />
    </main>
    <Footer />
  </body>
</html>
